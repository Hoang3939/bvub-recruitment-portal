@model BVUB_WebTuyenDung.Areas.Admin.ViewModels.UngTuyenVienChucViewModel
@{
    ViewData["Title"] = "Sửa đơn viên chức";
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}
<link rel="stylesheet" href="~/css/admin-edit.css" asp-append-version="true" />

@if (TempData["ModelErrors"] != null)
{
    <div class="alert alert-danger">@TempData["ModelErrors"]</div>
}

<form asp-area="Admin" asp-controller="DonVienChuc" asp-action="Edit" method="post" id="frmCreateVC">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="DonVienChuc.VienChucId" />
    <input type="hidden" asp-for="UngVien.UngVienId" />

    <h2>@ViewData["Title"]</h2>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <hr />
    <h4>Thông tin ứng viên</h4>

    <div class="form-group">
        <label asp-for="UngVien.Email">Email</label>
        <input asp-for="UngVien.Email" type="text" class="form-control" readonly />
        <span asp-validation-for="UngVien.Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.HoTen">Họ tên</label>
        <input asp-for="UngVien.HoTen" class="form-control" />
        <span asp-validation-for="UngVien.HoTen" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.GioiTinh">Giới tính</label>
        <select asp-for="UngVien.GioiTinh" class="form-control">
            <option value="0">Nam</option>
            <option value="1">Nữ</option>
        </select>
        <span asp-validation-for="UngVien.GioiTinh" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NgaySinh">Ngày sinh</label>
        <input asp-for="UngVien.NgaySinh" id="NgaySinh" class="form-control" type="date" autocomplete="off" max="@today" />
        <span asp-validation-for="UngVien.NgaySinh" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.SoDienThoai">Số điện thoại</label>
        <input asp-for="UngVien.SoDienThoai" class="form-control" type="tel" maxlength="11" />
        <span asp-validation-for="UngVien.SoDienThoai" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.CCCD">CCCD</label>
        <input asp-for="UngVien.CCCD" class="form-control" maxlength="12" />
        <span asp-validation-for="UngVien.CCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NgayCapCCCD">Ngày cấp Thẻ căn cước công dân hoặc thẻ căn cước</label>
        <input asp-for="UngVien.NgayCapCCCD" id="NgayCapCCCD" class="form-control" type="date" autocomplete="off" max="@today" />
        <span asp-validation-for="UngVien.NgayCapCCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NoiCapCCCD">Nơi cấp Thẻ căn cước công dân hoặc thẻ căn cước</label>
        <select asp-for="UngVien.NoiCapCCCD" class="form-control">
            <option value="">-- Chọn nơi cấp --</option>
            <option value="Bộ Công an">Bộ Công an</option>
            <option value="Cục Cảnh sát quản lý hành chính về trật tự xã hội">Cục Cảnh sát quản lý hành chính về trật tự xã hội</option>
            <option value="Cục Cảnh sát đăng ký quản lý cư trú và dữ liệu Quốc gia về dân cư">Cục Cảnh sát đăng ký quản lý cư trú và dữ liệu Quốc gia về dân cư</option>
        </select>
        <span asp-validation-for="UngVien.NoiCapCCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.DiaChiThuongTru">Địa chỉ thường trú</label>
        <input asp-for="UngVien.DiaChiThuongTru" class="form-control" />
        <span asp-validation-for="UngVien.DiaChiThuongTru" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.DiaChiCuTru">Địa chỉ nơi cư trú</label>
        <input asp-for="UngVien.DiaChiCuTru" class="form-control" />
        <span asp-validation-for="UngVien.DiaChiCuTru" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.MaSoThue">Mã số thuế</label>
        <input asp-for="UngVien.MaSoThue" class="form-control" maxlength="13" />
        <span asp-validation-for="UngVien.MaSoThue" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.SoTaiKhoan">Số tài khoản ngân hàng Vietinbank Chi nhánh 7</label>
        <input asp-for="UngVien.SoTaiKhoan" class="form-control" maxlength="12" />
        <span asp-validation-for="UngVien.SoTaiKhoan" class="text-danger"></span>
    </div>

    <!-- Tình trạng sức khỏe -->
    <div class="form-group">
        <label class="form-label fw-bold">Tình trạng sức khỏe</label>
        <input type="hidden" asp-for="UngVien.TinhTrangSucKhoe" id="hidSK" />
        <div class="form-check"><input class="radio-solid js-sk form-check-input" type="radio" name="skUI" value="Loại I" id="sk1"><label for="sk1">Loại I</label></div>
        <div class="form-check"><input class="radio-solid js-sk form-check-input" type="radio" name="skUI" value="Loại II" id="sk2"><label for="sk2">Loại II</label></div>
        <div class="form-check"><input class="radio-solid js-sk form-check-input" type="radio" name="skUI" value="Loại III" id="sk3"><label for="sk3">Loại III</label></div>
        <div class="form-check"><input class="radio-solid js-sk form-check-input" type="radio" name="skUI" value="__OTHER__" id="skKhac"><label for="skKhac">Khác</label></div>
        <input type="text" class="form-control" id="txtSkKhac" placeholder="Nhập tình trạng khác" style="display:none;" />
        <span asp-validation-for="UngVien.TinhTrangSucKhoe" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.TrinhDoChuyenMon">Trình độ chuyên môn/Trình độ đào tạo</label>
        <input asp-for="UngVien.TrinhDoChuyenMon" class="form-control" />
        <span asp-validation-for="UngVien.TrinhDoChuyenMon" class="text-danger"></span>
    </div>

    <hr />
    <h4>Thông tin dự tuyển</h4>

    <div class="form-group">
        <label>Chức danh nghề nghiệp dự tuyển</label>
        <select id="ChucDanhId" class="form-control"
                asp-for="DonVienChuc.ChucDanhDuTuyenId"
                asp-items="ViewBag.ChucDanhList">
            <option value="">-- Chọn chức danh --</option>
        </select>
    </div>

    <div class="form-group">
        <label asp-for="DonVienChuc.ViTriDuTuyenId">Vị trí việc làm dự tuyển</label>
        <select id="ViTriId"
                asp-for="DonVienChuc.ViTriDuTuyenId"
                class="form-control"
                asp-items="ViewBag.ViTriList">
            @if (ViewBag.ViTriList == null && Model?.DonVienChuc?.ViTriDuTuyenId != null)
            {
                <option selected value="@Model.DonVienChuc.ViTriDuTuyenId">@Model.DonVienChuc.ViTriDuTuyen?.TenViTri</option>
            }
            <option value="">-- Chọn vị trí --</option>
        </select>
        <span asp-validation-for="DonVienChuc.ViTriDuTuyenId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DonVienChuc.KhoaPhongId">Khoa/Phòng dự tuyển</label>
        <select id="KhoaPhongId" asp-for="DonVienChuc.KhoaPhongId" class="form-control">
            @if (Model?.DonVienChuc?.KhoaPhongId != null)
            {
                <option selected value="@Model.DonVienChuc.KhoaPhongId">@Model.DonVienChuc.KhoaPhong?.Ten</option>
            }
            <option value="">-- Chọn khoa/phòng --</option>
        </select>
        <span asp-validation-for="DonVienChuc.KhoaPhongId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DonVienChuc.DanToc">Dân tộc</label>
        <input asp-for="DonVienChuc.DanToc" class="form-control" />
        <span asp-validation-for="DonVienChuc.DanToc" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DonVienChuc.TonGiao">Tôn giáo</label>
        <input asp-for="DonVienChuc.TonGiao" class="form-control" />
        <span asp-validation-for="DonVienChuc.TonGiao" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DonVienChuc.QueQuan">Quê quán</label>
        <input asp-for="DonVienChuc.QueQuan" class="form-control" />
        <span asp-validation-for="DonVienChuc.QueQuan" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DonVienChuc.HoKhau">Thông tin về hộ khẩu (nếu có)</label>
        <input asp-for="DonVienChuc.HoKhau" class="form-control" />
        <span asp-validation-for="DonVienChuc.HoKhau" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DonVienChuc.ChieuCao">Chiều cao (cm)</label>
        <input asp-for="DonVienChuc.ChieuCao" class="form-control" type="number" inputmode="numeric" autocomplete="off" />
        <span asp-validation-for="DonVienChuc.ChieuCao" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DonVienChuc.CanNang">Cân nặng (kg)</label>
        <input asp-for="DonVienChuc.CanNang" class="form-control" type="number" inputmode="numeric" autocomplete="off" />
        <span asp-validation-for="DonVienChuc.CanNang" class="text-danger"></span>
    </div>

    <!-- Trình độ văn hóa -->
    <div class="form-group">
        <label class="form-label fw-bold">Trình độ văn hóa</label>
        <input type="hidden" asp-for="DonVienChuc.TrinhDoVanHoa" id="hidTDVH" />
        <div class="form-check"><input class="radio-solid js-tdvh form-check-input" type="radio" name="tdvhUI" value="12/12 Chính quy" id="tdvh1"><label for="tdvh1">12/12 Chính quy</label></div>
        <div class="form-check"><input class="radio-solid js-tdvh form-check-input" type="radio" name="tdvhUI" value="12/12 Bổ túc văn hóa" id="tdvh2"><label for="tdvh2">12/12 Bổ túc văn hóa</label></div>
        <div class="form-check"><input class="radio-solid js-tdvh form-check-input" type="radio" name="tdvhUI" value="__OTHER__" id="tdvhKhac"><label for="tdvhKhac">Khác</label></div>
        <input type="text" class="form-control" id="txtTrinhDoKhac" placeholder="Nhập trình độ văn hóa khác" style="display:none;" />
        <span asp-validation-for="DonVienChuc.TrinhDoVanHoa" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DonVienChuc.LoaiHinhDaoTao">Loại hình đào tạo</label>
        <input asp-for="DonVienChuc.LoaiHinhDaoTao" class="form-control" />
        <span asp-validation-for="DonVienChuc.LoaiHinhDaoTao" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DonVienChuc.DoiTuongUuTien">Đối tượng ưu tiên</label>
        <input asp-for="DonVienChuc.DoiTuongUuTien" class="form-control" />
        <span asp-validation-for="DonVienChuc.DoiTuongUuTien" class="text-danger"></span>
    </div>

    <hr />
    <h4>Văn bằng</h4>

    <div id="vanbang-container">
        @if (Model?.VanBangs != null && Model.VanBangs.Count > 0)
        {
            for (int i = 0; i < Model.VanBangs.Count; i++)
            {
                var vb = Model.VanBangs[i];
                var ht = vb?.HinhThucDaoTao?.Trim() ?? "";
                var isCQ = string.Equals(ht, "Chính quy", StringComparison.OrdinalIgnoreCase);
                var isTC = string.Equals(ht, "Tại chức", StringComparison.OrdinalIgnoreCase);
                var isLT = string.Equals(ht, "Liên thông", StringComparison.OrdinalIgnoreCase);
                var isTX = string.Equals(ht, "Từ xa", StringComparison.OrdinalIgnoreCase);
                var isOtherHT = !(isCQ || isTC || isLT || isTX);
                <div class="vanbang-block">
                    <h5>Văn bằng: @vb.LoaiVanBang</h5>

                    <!-- Giữ loại & FK Ứng viên -->
                    <input type="hidden" name="VanBangs[@i].LoaiVanBang" value="@vb.LoaiVanBang" />
                    <input type="hidden" name="VanBangs[@i].UngVienId" value="@Model.UngVien.UngVienId" /> 

                    <div class="form-group">
                        <label>Tên cơ sở cấp</label>
                        <input name="VanBangs[@i].TenCoSo" class="form-control" type="text" value="@(vb.TenCoSo ?? "")" />
                    </div>

                    <div class="form-group">
                        <label>Ngày cấp</label>
                        <input name="VanBangs[@i].NgayCap" class="form-control" type="date" value="@(vb.NgayCap == default(DateTime) ? "" : vb.NgayCap?.ToString("yyyy-MM-dd"))" />
                    </div>

                    <div class="form-group">
                        <label>Số hiệu</label>
                        <input name="VanBangs[@i].SoHieu" class="form-control" type="text" value="@(vb.SoHieu ?? "")" />
                    </div>

                    <div class="form-group">
                        <label>Chuyên ngành đào tạo</label>
                        <input name="VanBangs[@i].ChuyenNganhDaoTao" class="form-control" type="text" value="@(vb.ChuyenNganhDaoTao ?? "")" />
                    </div>

                    <div class="form-group">
                        <label>Ngành đào tạo</label>
                        <input name="VanBangs[@i].NganhDaoTao" class="form-control" type="text" value="@(vb.NganhDaoTao ?? "")" />
                    </div>

                    <div class="form-group">
                        <label>Hình thức đào tạo</label>

                        <input type="hidden" name="VanBangs[@i].HinhThucDaoTao" class="vb-ht-hidden" data-index="@i" value="@ht" />

                        <div class="form-check"><input type="radio" name="vb-ht-@i" value="Chính quy" class="radio-solid vb-ht form-check-input" @(isCQ ? "checked" : "") id="vbht-@i-1"><label for="vbht-@i-1">Chính quy</label></div>
                        <div class="form-check"><input type="radio" name="vb-ht-@i" value="Tại chức" class="radio-solid vb-ht form-check-input" @(isTC ? "checked" : "") id="vbht-@i-2"><label for="vbht-@i-2">Tại chức</label></div>
                        <div class="form-check"><input type="radio" name="vb-ht-@i" value="Liên thông" class="radio-solid vb-ht form-check-input" @(isLT ? "checked" : "") id="vbht-@i-3"><label for="vbht-@i-3">Liên thông</label></div>
                        <div class="form-check"><input type="radio" name="vb-ht-@i" value="Từ xa" class="radio-solid vb-ht form-check-input" @(isTX ? "checked" : "") id="vbht-@i-4"><label for="vbht-@i-4">Từ xa</label></div>
                        <div class="form-check"><input type="radio" name="vb-ht-@i" value="__OTHER__" class="radio-solid vb-ht form-check-input" @(isOtherHT ? "checked" : "") id="vbht-@i-5"><label for="vbht-@i-5">Khác</label></div>

                        <input type="text" class="form-control vb-ht-other" data-index="@i"
                               placeholder="Nhập hình thức đào tạo khác"
                               style="display:@(isOtherHT ? "block" : "none");"
                               value="@(isOtherHT ? ht : "")" />
                    </div>

                    <div class="form-group">
                        <label>Xếp loại</label>
                        <input name="VanBangs[@i].XepLoai" class="form-control" type="text" value="@(vb.XepLoai ?? "")" />
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted">Không có văn bằng nào.</p>
        }
    </div>

    <div style="margin-top: 16px;">
        <button type="submit" class="btn btn-primary" id="btnSave">Lưu</button>
        <a class="btn btn-secondary" href="@Url.Action("Index","Candidates", new { area="Admin" })">Quay lại</a>
    </div>
</form>

<div id="saveConfirm" class="modal-overlay" aria-hidden="true">
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="saveTitle">
        <div class="modal-header">
            <h3 id="saveTitle" class="modal-title">Xác nhận lưu</h3>
            <button type="button" class="modal-close" aria-label="Đóng">&times;</button>
        </div>
        <div class="modal-body">
            <p style="margin:0">Bạn có chắc muốn lưu thay đổi cho đơn viên chức?</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-export" id="btnCancelSave">Hủy</button>
            <button type="button" class="btn btn-primary" id="btnOkSave">Lưu</button>
        </div>
    </div>
</div>

<!-- Config cho JS -->
<div id="admin-vc-edit-config"
     data-today='@today'
     data-url-vitri-by-chucdanh='@Url.Action("GetViTriByChucDanh", "DonVienChuc", new { area = "Admin" })'
     data-url-khoaphong-by-vitri='@Url.Action("GetKhoaPhongByViTri", "DonVienChuc", new { area = "Admin" })'
     data-back-url='@Url.Action("Index", "Candidates", new { area = "Admin" })'>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin.donvienchuc.edit.js" asp-append-version="true"></script>
}
