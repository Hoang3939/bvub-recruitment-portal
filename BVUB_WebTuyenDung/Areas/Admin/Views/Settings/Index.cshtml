@model BVUB_WebTuyenDung.Areas.Admin.ViewModels.EmailSettingsIndexVM
@{
    ViewData["Title"] = "Cài đặt";
}

<h2 class="mb-3">Cài đặt Email</h2>

@if (TempData["ToastSuccess"] != null)
{
    <div class="alert alert-success">@TempData["ToastSuccess"]</div>
}

<style>
    /* ============ CHỈ ÁP DỤNG TRANG NÀY ============ */
    .settings-page .row {
        row-gap: 1.5rem;
    }

    /* Hai cột email: card cao bằng nhau */
    .settings-page .col-half {
        display: flex;
    }

        .settings-page .col-half .card {
            width: 100%;
            display: flex;
            flex-direction: column;
        }

    .settings-page .card {
        border: 1px solid rgba(0, 0, 0, .125) !important;
        border-left: 1px solid rgba(0, 0, 0, .125) !important;
        border-radius: .375rem !important;
        background: #fff !important;
    }

    .settings-page .card-header {
        padding: .75rem 1rem;
        background: #f8f9fa !important;
        color: #212529 !important;
        border-bottom: 1px solid rgba(0, 0, 0, .125) !important;
        border-top-left-radius: calc(.375rem - 1px) !important;
        border-top-right-radius: calc(.375rem - 1px) !important;
    }

    .settings-page .card-body {
        flex: 1;
        padding: 1.25rem !important;
    }

    /* DẸP HOÀN TOÀN “Ô TRẮNG BO GÓC” QUANH FORM (mọi cấp) */
    .content .settings-page form,
    .content .settings-page .card form,
    .content .settings-page .card .card-body form,
    .content .settings-page .card .card-body > form,
    .content .settings-page .card .card-body *:has(> form) {
        background: transparent !important;
        border: 0 !important;
        box-shadow: none !important;
        padding: 0 !important;
        border-radius: 0 !important;
    }

    /* Form bên phải stretch full height trong card */
    .settings-page .card-body form {
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .settings-page .card-body form .btn {
        margin-top: auto;
    }

    .email-settings-section .card-body {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        padding: 1.75rem !important;
    }

    .email-settings-section .email-settings-stack {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
    }

    .email-settings-section .email-settings-stack > .mb-3 {
        margin-bottom: 0 !important;
    }

    .email-settings-section .email-settings-form {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        width: 100%;
        margin: 0;
    }

    .email-settings-section .email-settings-form .btn {
        width: 100%;
        margin-top: 1rem;
    }

    .email-settings-section .validation-summary-valid,
    .email-settings-section .validation-summary-errors:empty {
        display: none;
    }

    .email-settings-section .validation-summary-errors {
        margin-bottom: 1rem !important;
    }

    /* Cảm giác đồng bộ */
    .settings-page .form-label {
        margin-bottom: .4rem;
    }

    .settings-page .mb-3 {
        margin-bottom: 1rem !important;
    }

    .settings-page .form-control {
        border-radius: .6rem;
    }

        /* Input readonly bên trái cho nền trắng giống input thường */
        .settings-page .form-control[readonly] {
            background: #fff;
            opacity: 1;
        }

    /* ====== Custom Switch đẹp (không lệ thuộc Bootstrap) ====== */
    .switch {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        user-select: none;
    }

        .switch input {
            display: none;
        }

        .switch .slider {
            width: 46px;
            height: 26px;
            border-radius: 999px;
            background: #e5e7eb;
            position: relative;
            transition: background .2s;
            box-shadow: inset 0 0 0 1px rgba(0,0,0,.08);
        }

            .switch .slider::after {
                content: "";
                position: absolute;
                top: 3px;
                left: 3px;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: #fff;
                box-shadow: 0 1px 3px rgba(0,0,0,.2);
                transition: transform .2s;
            }

        .switch input:checked + .slider {
            background: #0d6efd;
        }

            .switch input:checked + .slider::after {
                transform: translateX(20px);
            }

        .switch .text {
            font-size: .95rem;
            color: #374151;
        }
</style>

<div class="settings-page email-settings-section">
    <div class="row g-4 align-items-stretch">
        <!-- CỘT TRÁI -->
        <div class="col-12 col-md-6 col-half">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">Cấu hình hiện tại</div>
                <div class="card-body">
                    <div class="email-settings-stack">
                        <div class="mb-3">
                            <label class="form-label">Username (SMTP)</label>
                            <input class="form-control" value="@Model.Current?.Username" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">AppPassword (SMTP)</label>
                            <input class="form-control" value="********" readonly />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: Chỉ cho đổi Username + Password -->
        <div class="col-12 col-md-6 col-half">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">Cập nhật tài khoản gửi mail</div>
                <div class="card-body">
                    <form asp-action="Index" method="post" novalidate class="email-settings-form">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-0"></div>

                        <div class="email-settings-stack">
                            <div class="mb-3">
                                <label class="form-label">Username (SMTP)</label>
                                <input asp-for="Form.Username" class="form-control" />
                                <span asp-validation-for="Form.Username" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">AppPassword (SMTP)</label>
                                <input asp-for="Form.Password" type="password" class="form-control" placeholder="Để trống nếu không đổi" />
                                <span asp-validation-for="Form.Password" class="text-danger"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Lưu
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== Khóa / Mở link ứng tuyển ===== -->
<h2 class="mb-3 mt-5">Khóa / Mở link ứng tuyển</h2>
<div class="settings-page">
    <div class="row g-4">
        <!-- Link Viên chức -->
        <div class="col-12 col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">Link Viên chức</div>
                <div class="card-body">
                    <form asp-action="ToggleLink" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="type" value="VC" />
                        <input type="hidden" name="open" value="@(ViewBag.LinkVCOpen == true ? "false" : "true")" />
                        <label class="switch">
                            <input type="checkbox" @(ViewBag.LinkVCOpen == true ? "checked" : "")
                                   onchange="this.form.submit()" />
                            <span class="slider"></span>
                            <span class="text">@(ViewBag.LinkVCOpen == true ? "Đang MỞ" : "Đang KHÓA")</span>
                        </label>
                    </form>
                </div>
            </div>
        </div>

        <!-- Link Người lao động -->
        <div class="col-12 col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">Link Người lao động</div>
                <div class="card-body">
                    <form asp-action="ToggleLink" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="type" value="NLD" />
                        <input type="hidden" name="open" value="@(ViewBag.LinkNLDOpen == true ? "false" : "true")" />
                        <label class="switch">
                            <input type="checkbox" @(ViewBag.LinkNLDOpen == true ? "checked" : "")
                                   onchange="this.form.submit()" />
                            <span class="slider"></span>
                            <span class="text">@(ViewBag.LinkNLDOpen == true ? "Đang MỞ" : "Đang KHÓA")</span>
                        </label>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}