@model IEnumerable<BVUB_WebTuyenDung.Areas.Admin.Models.AuditTrail>

@{
    ViewData["Title"] = "Nhật ký hệ thống";
    var username = ViewBag.Username as string ?? "";
    var fromDate = ViewBag.FromDate as string ?? "";
    var toDate = ViewBag.ToDate as string ?? "";
    var hasFilter = ViewBag.HasFilter as bool? ?? false;
}

<h2>Nhật ký hệ thống</h2>

<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Tài khoản</label>
            <input type="text" name="username" value="@username" class="form-control" placeholder="Nhập username..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Từ ngày</label>
            <input type="text" id="from" name="from" value="@fromDate" class="form-control js-date" autocomplete="off" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Đến ngày</label>
            <input type="text" id="to" name="to" value="@toDate" class="form-control js-date" autocomplete="off" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            @if (!hasFilter)
            {
                <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Lọc</button>
            }
            else
            {
                <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Bỏ lọc</a>
            }
        </div>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Người thao tác</th>
            <th>Thao tác</th>
            <th>Ngày giờ</th>
        </tr>
    </thead>
    <tbody>
        @if (!(Model?.Any() ?? false))
        {
            <tr><td colspan="4" class="text-center text-muted">Không có dữ liệu.</td></tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.AuditTrailId</td>
                    <td>@item.UserName</td>
                    <td>@item.Action</td>
                    <td>@item.ActionDate.ToString("dd/MM/yyyy HH:mm:ss")</td>
                </tr>
            }
        }
    </tbody>
</table>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script>
        flatpickr(".js-date", {
            dateFormat: "d/m/Y",
            altInput: true,
            altFormat: "d/m/Y",
            locale: "vn",
            maxDate: "today"
        });

        // ràng buộc from <= to
        const fromInput = document.getElementById("from");
        const toInput = document.getElementById("to");
        fromInput._flatpickr.config.onChange.push(function (selDates) {
            if (selDates.length > 0) {
                toInput._flatpickr.set("minDate", selDates[0]);
            }
        });
        toInput._flatpickr.config.onChange.push(function (selDates) {
            if (selDates.length > 0) {
                fromInput._flatpickr.set("maxDate", selDates[0]);
            }
        });
    </script>
}