@model BVUB_WebTuyenDung.Areas.Admin.ViewModels.DepartmentFrmVm
@using System.Text.Json
@{
    ViewData["Title"] = "Thêm Khoa/Phòng";
    var preSelectedJson = JsonSerializer.Serialize(Model?.SelectedViTriIds ?? new List<int>());
}
<link rel="stylesheet" href="~/css/admin-departments-create.css" asp-append-version="true" />

<h2>@ViewData["Title"]</h2>

@if (TempData["ToastError"] != null)
{
    <div class="alert alert-danger" role="alert">@TempData["ToastError"]</div>
}

<form method="post" asp-action="Create">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <!-- Tên -->
        <div class="col-lg-6 col-md-6">
            <label asp-for="Ten" class="form-label">Tên</label>
            <input asp-for="Ten" class="form-control" placeholder="Nhập tên khoa/phòng" />
            <span asp-validation-for="Ten" class="text-danger"></span>
        </div>

        <!-- Loại -->
        <div class="col-lg-3 col-md-3">
            <label asp-for="Loai" class="form-label">Loại</label>
            <select asp-for="Loai" class="form-select">
                <option value="Khoa" selected="@(Model?.Loai=="Khoa")">Khoa</option>
                <option value="Phòng" selected="@(Model?.Loai=="Phòng")">Phòng</option>
            </select>
        </div>

        <!-- Trạng thái -->
        <div class="col-lg-3 col-md-3">
            <label asp-for="TamNgung" class="form-label">Trạng thái</label>
            <select asp-for="TamNgung" class="form-select">
                <option value="0" selected="@(Model?.TamNgung==0)">Sử dụng</option>
                <option value="1" selected="@(Model?.TamNgung==1)">Tạm ngưng</option>
            </select>
        </div>

        <!-- Chức danh (lọc vị trí) -->
        <div class="col-12">
            <label class="form-label">Chức danh (để lọc vị trí)</label>
            <select class="form-select" id="ddlTitle">
                <option value="">-- chọn chức danh --</option>
                @foreach (var t in Model.AllChucDanhs)
                {
                    <option value="@t.Value">@t.Text</option>
                }
            </select>
        </div>

        <!-- Bảng vị trí theo chức danh -->
        <div class="col-12">
            <div class="pos-grid" id="posGrid"><!-- render qua JS --></div>
        </div>

        <!-- Khối vị trí ĐÃ CHỌN (tích lũy) -->
        <div class="col-12">
            <label class="form-label">Đã chọn</label>
            <div id="selectedList" class="selected-grid"><!-- chip render tại đây --></div>
            <div id="selectedHidden"><!-- hidden inputs SelectedViTriIds[] --></div>
            <span asp-validation-for="SelectedViTriIds" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary">Lưu</button>
        <a asp-action="Index" class="btn btn-link">Hủy</a>
    </div>
</form>

<!-- Config cho JS -->
<div id="admin-dept-form-config"
     data-preselected='@preSelectedJson'
     data-url-by-title='@Url.Action("GetPositionsByTitle", "Departments", new { area = "Admin" })'
     data-url-by-ids='@Url.Action("GetPositionsByIds", "Departments", new { area = "Admin" })'>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin.departments.form.js" asp-append-version="true"></script>
}
