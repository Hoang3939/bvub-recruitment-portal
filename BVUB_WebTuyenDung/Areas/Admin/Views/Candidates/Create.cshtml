@model BVUB_WebTuyenDung.Areas.Admin.ViewModels.CreateCandidateVm
@{
    ViewData["Title"] = "Thêm ứng viên";

    // Dùng cho max date
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}

<link rel="stylesheet" href="~/css/admin-candidates-index.css" asp-append-version="true" />

<div class="main-content">
    <div class="header-row">
        <h2>Thêm ứng viên</h2>
    </div>

    <form asp-action="Create" method="post" novalidate id="frmCreateUv">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="alert alert-danger mb-3" role="alert"></div>

        <div class="form-group mb-3">
            <span id="lblHoTen" class="field-title">@Html.DisplayNameFor(m => m.HoTen)</span>
            <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên" aria-labelledby="lblHoTen" maxlength="100" />
            <span asp-validation-for="HoTen" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <span id="lblNgaySinh" class="field-title">@Html.DisplayNameFor(m => m.NgaySinh)</span>
                <input asp-for="NgaySinh" type="date" class="form-control" aria-labelledby="lblNgaySinh" max="@today" />
                <span asp-validation-for="NgaySinh" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <span id="lblGioiTinh" class="field-title">@Html.DisplayNameFor(m => m.GioiTinh)</span>
                <select asp-for="GioiTinh" class="form-select" aria-labelledby="lblGioiTinh">
                    <option value="">-- Chọn giới tính --</option>
                    <option value="1">Nữ</option>
                    <option value="0">Nam</option>
                </select>
                <span asp-validation-for="GioiTinh" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <span id="lblNgayUngTuyen" class="field-title">@Html.DisplayNameFor(m => m.NgayUngTuyen)</span>
                <input asp-for="NgayUngTuyen"
                       type="date"
                       class="form-control"
                       aria-labelledby="lblNgayUngTuyen"
                       value="@(Model?.NgayUngTuyen == default ? DateTime.Today.ToString("yyyy-MM-dd") : Model.NgayUngTuyen.ToString("yyyy-MM-dd"))" />
                <span asp-validation-for="NgayUngTuyen" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mt-0">
            <div class="col-md-4">
                <span id="lblSDT" class="field-title">@Html.DisplayNameFor(m => m.SoDienThoai)</span>
                <input asp-for="SoDienThoai" class="form-control" placeholder="VD: 09xxxxxxxx" aria-labelledby="lblSDT" inputmode="numeric" maxlength="11" />
                <span asp-validation-for="SoDienThoai" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <span id="lblEmail" class="field-title">@Html.DisplayNameFor(m => m.Email)</span>
                <input asp-for="Email" type="email" class="form-control" placeholder="email@domain.com" aria-labelledby="lblEmail" maxlength="256" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <span id="lblCCCD" class="field-title">@Html.DisplayNameFor(m => m.CCCD)</span>
                <input asp-for="CCCD" class="form-control" placeholder="Số CCCD" aria-labelledby="lblCCCD" inputmode="numeric" maxlength="12" />
                <span asp-validation-for="CCCD" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mt-0">
            <div class="col-md-4">
                <span id="lblNgayCap" class="field-title">@Html.DisplayNameFor(m => m.NgayCapCCCD)</span>
                <input asp-for="NgayCapCCCD" type="date" class="form-control" aria-labelledby="lblNgayCap" max="@today" />
                <span asp-validation-for="NgayCapCCCD" class="text-danger"></span>
            </div>

            <div class="col-md-8">
                <span id="lblNoiCap" class="field-title">@Html.DisplayNameFor(m => m.NoiCapCCCD)</span>
                <select asp-for="NoiCapCCCD" class="form-select" aria-labelledby="lblNoiCap">
                    <option value="">-- Chọn nơi cấp --</option>
                    <option value="Bộ Công An">Bộ Công An</option>
                    <option value="Cục Cảnh sát quản lý hành chính về trật tự xã hội">Cục Cảnh sát quản lý hành chính về trật tự xã hội</option>
                    <option value="Cục Cảnh sát đăng ký quản lý cư trú và dữ liệu Quốc gia về dân cư">
                        Cục Cảnh sát đăng ký quản lý cư trú và dữ liệu Quốc gia về dân cư
                    </option>
                </select>
                <span asp-validation-for="NoiCapCCCD" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group mt-3">
            <span id="lblThuongTru" class="field-title">@Html.DisplayNameFor(m => m.DiaChiThuongTru)</span>
            <input asp-for="DiaChiThuongTru" class="form-control" placeholder="Nhập địa chỉ thường trú" aria-labelledby="lblThuongTru" maxlength="255" />
            <span asp-validation-for="DiaChiThuongTru" class="text-danger"></span>
        </div>

        <div class="form-group mt-3">
            <span id="lblCuTru" class="field-title">@Html.DisplayNameFor(m => m.DiaChiCuTru)</span>
            <input asp-for="DiaChiCuTru" class="form-control" placeholder="Nhập địa chỉ cư trú" aria-labelledby="lblCuTru" maxlength="255" />
            <span asp-validation-for="DiaChiCuTru" class="text-danger"></span>
        </div>

        <div class="row g-3 mt-0">
            <div class="col-md-4">
                <span id="lblMST" class="field-title">@Html.DisplayNameFor(m => m.MaSoThue)</span>
                <input asp-for="MaSoThue" class="form-control" placeholder="Mã số thuế" aria-labelledby="lblMST" inputmode="numeric" maxlength="13" />
                <span asp-validation-for="MaSoThue" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <span id="lblSTK" class="field-title">@Html.DisplayNameFor(m => m.SoTaiKhoan)</span>
                <input asp-for="SoTaiKhoan" class="form-control" placeholder="Số tài khoản" aria-labelledby="lblSTK" inputmode="numeric" maxlength="20" />
                <span asp-validation-for="SoTaiKhoan" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <span id="lblSucKhoe" class="field-title">@Html.DisplayNameFor(m => m.TinhTrangSucKhoe)</span>

                <select id="TinhTrangSelect" class="form-select" aria-labelledby="lblSucKhoe">
                    <option value="">-- Chọn tình trạng --</option>
                    <option value="Loại I">Loại I</option>
                    <option value="Loại II">Loại II</option>
                    <option value="Loại III">Loại III</option>
                    <option value="__OTHER__">Khác</option>
                </select>

                <div id="TinhTrangOtherWrap" class="mt-2" style="display:none">
                    <input id="TinhTrangOther" class="form-control" placeholder="Nhập tình trạng khác" maxlength="100" />
                </div>

                <!-- Hidden bind về server -->
                <input type="hidden" asp-for="TinhTrangSucKhoe" />
                <span asp-validation-for="TinhTrangSucKhoe" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group mt-3">
            <span id="lblTrinhDo" class="field-title">@Html.DisplayNameFor(m => m.TrinhDoChuyenMon)</span>
            <input asp-for="TrinhDoChuyenMon" class="form-control" placeholder="VD: Bác sĩ đa khoa" aria-labelledby="lblTrinhDo" maxlength="100" />
            <span asp-validation-for="TrinhDoChuyenMon" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" name="action" value="save" class="btn btn-primary">Lưu</button>
            <button type="submit" name="action" value="save-vc" class="btn btn-success">Lưu &amp; tạo Đơn viên chức</button>
            <button type="submit" name="action" value="save-hd" class="btn btn-secondary">Lưu &amp; tạo HĐ người lao động</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin.candidates.create.js" asp-append-version="true"></script>
}
