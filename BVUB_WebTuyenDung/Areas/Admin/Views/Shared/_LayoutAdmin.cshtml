@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Security.Claims

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var username = User.Identity?.IsAuthenticated == true
        ? User.Identity.Name
        : null;

    var roleClaim = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;

    // Map hiển thị vai trò
    string roleDisplay = roleClaim switch
    {
        "Admin" => "Quản trị viên",
        "Staff" => "Nhân viên",
        "1" => "Quản trị viên",
        "2" => "Nhân viên",
        _ => roleClaim ?? ""
    };

    bool isAdmin = User.IsInRole("Admin") || roleClaim == "1";
    bool isStaff = User.IsInRole("Staff") || roleClaim == "2";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Quản trị</title>

    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin-layout.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.11.8/umd/popper.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.min.js"></script>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="header">
            <img src="~/images/logo.png" alt="Logo" />
            <h1>
                Bệnh viện Ung Bướu<br />
                <small style="font-size: 12px;">Thành phố Hồ Chí Minh</small>
            </h1>
        </div>

        <ul class="nav-menu">
            <!-- Bảng điều khiển: Staff + Admin -->
            <li>
                <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index"
                   class="@(currentController == "HomeAdmin" ? "active" : "")">
                    <i class="fas fa-chart-line"></i><span> Bảng điều khiển</span>
                </a>
            </li>

            @if (isAdmin)
            {
                <!-- Chỉ Admin -->
                <li>
                    <a asp-area="Admin" asp-controller="Employees" asp-action="Index"
                       class="@(currentController == "Employees" ? "active" : "")">
                        <i class="fas fa-users"></i><span> Nhân viên</span>
                    </a>
                </li>
            }

            <!-- Ứng viên: Staff + Admin -->
            <li>
                <a asp-area="Admin" asp-controller="Candidates" asp-action="Index"
                   class="@(currentController == "Candidates" ? "active" : "")">
                    <i class="fas fa-user-tie"></i><span> Ứng viên</span>
                </a>
            </li>

            @if (isAdmin)
            {
                <!-- Chỉ Admin -->
                <li>
                    <a asp-area="Admin" asp-controller="Recruitments" asp-action="Index"
                       class="@(currentController == "Recruitments" ? "active" : "")">
                        <i class="fas fa-briefcase"></i><span> Thông tin tuyển dụng</span>
                    </a>
                </li>
                <li>
                    <a asp-area="Admin" asp-controller="Departments" asp-action="Index"
                       class="@(currentController == "Departments" ? "active" : "")">
                        <i class="fas fa-building"></i><span> Khoa phòng</span>
                    </a>
                </li>
                <li>
                    <a asp-area="Admin" asp-controller="Positions" asp-action="Index"
                       class="@(currentController == "Positions" ? "active" : "")">
                        <i class="fas fa-tasks"></i><span> Vị trí dự tuyển</span>
                    </a>
                </li>
                <li>
                    <a asp-area="Admin" asp-controller="Titles" asp-action="Index"
                       class="@(currentController == "Titles" ? "active" : "")">
                        <i class="fas fa-id-badge"></i><span> Chức danh dự tuyển</span>
                    </a>
                </li>
            }

            <!-- Báo cáo thống kê: Staff + Admin -->
            <li>
                <a asp-area="Admin" asp-controller="Reports" asp-action="Index"
                   class="@(currentController == "Reports" ? "active" : "")">
                    <i class="fas fa-chart-bar"></i><span> Báo cáo thống kê</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- Main content -->
    <div class="main" id="main">
        <div class="topbar">
            <div class="d-flex align-items-center">
                <div class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </div>
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Tìm kiếm..." />
                </div>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="dropdown profile">
                    <a class="d-flex align-items-center text-decoration-none dropdown-toggle profile-name" href="#"
                       role="button" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="~/images/avtAD.jpg" alt="Avatar" width="32" height="32">
                        <div class="name-role">
                            <span class="name">@username</span>
                            <span class="role">@roleDisplay</span>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="dropdownUser">
                        <li>
                            <a class="dropdown-item" asp-area="Admin" asp-controller="Account" asp-action="Profile">
                                <i class="fas fa-user-circle me-2 text-primary"></i> Quản lý tài khoản
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-area="Admin" asp-controller="ChangePassword" asp-action="Index">
                                <i class="fas fa-key me-2 text-danger"></i> Đổi mật khẩu
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a class="dropdown-item"
                               href="@Url.Action("Logout", "Account", new { area = "Admin" })">
                                <i class="fas fa-sign-out-alt me-2 text-warning"></i> Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a asp-area="Admin" asp-controller="Account" asp-action="Login" class="btn btn-light">Đăng nhập</a>
            }
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.getElementById('main').classList.toggle('collapsed');
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
