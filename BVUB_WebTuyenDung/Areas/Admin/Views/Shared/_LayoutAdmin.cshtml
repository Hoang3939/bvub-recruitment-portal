@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Security.Claims
@using BVUB_WebTuyenDung.Areas.Admin.Security

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var username = User.Identity?.IsAuthenticated == true ? User.Identity.Name : null;

    // ==> LẤY ROLE DẠNG CHUỖI CHO HIỂN THỊ ("Admin" | "Staff")
    var roleName = User.FindFirst(ClaimTypes.Role)?.Value;

    // ==> ADMIN nếu có role "Admin" hoặc role "1"
    bool isAdmin =
        string.Equals(roleName, "Admin", StringComparison.OrdinalIgnoreCase)
        || User.IsInRole("Admin")
        || User.IsInRole("1");

    // ==> LẤY BITMASK QUYỀN MENU từ claim "MenuPerms" (ví dụ 2|4|8...)
    int permBits = 0;
    int.TryParse(User.FindFirst("MenuPerms")?.Value ?? "0", out permBits);

    // ==> HÀM KIỂM TRA QUYỀN MENU
    bool Can(StaffPerms p) => isAdmin || ((permBits & (int)p) == (int)p);

    // ==> DÒNG HIỂN THỊ VAI TRÒ
    string roleDisplay = isAdmin ? "Quản trị viên" : "Nhân viên";

    // ==> Tab hiện tại (để set active đúng khi ở Departments)
    var currentTab = (Context?.Request?.Query["tab"].ToString() ?? "").ToLower();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.11.8/umd/popper.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.min.js"></script>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="header">
            <img src="~/images/logo.png" alt="Logo" />
            <h1>
                Bệnh viện Ung Bướu<br />
                <small style="font-size: 12px;">Thành phố Hồ Chí Minh</small>
            </h1>
        </div>

        <ul class="nav-menu">
            <!-- Bảng điều khiển -->
            @if (Can(StaffPerms.Dashboard))
            {
                <li>
                    <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index"
                       class="@(currentController == "HomeAdmin" ? "active" : "")">
                        <i class="fas fa-chart-line"></i><span> Bảng điều khiển</span>
                    </a>
                </li>
            }

            <!-- Nhân viên: chỉ Admin -->
            @if (isAdmin)
            {
                <li>
                    <a asp-area="Admin" asp-controller="Employee" asp-action="Index"
                       class="@(currentController == "Employee" ? "active" : "")">
                        <i class="fas fa-users"></i><span> Nhân viên</span>
                    </a>
                </li>
            }

            <!-- Ứng viên -->
            @if (Can(StaffPerms.Candidates))
            {
                <li>
                    <a asp-area="Admin" asp-controller="Candidates" asp-action="Index"
                       class="@(currentController == "Candidates" ? "active" : "")">
                        <i class="fas fa-user-tie"></i><span> Ứng viên</span>
                    </a>
                </li>
            }

            <!-- Thông tin tuyển dụng -->
            @if (Can(StaffPerms.Recruitments))
            {
                <li>
                    <a asp-area="Admin" asp-controller="Recruitments" asp-action="Index"
                       class="@(currentController == "Recruitments" ? "active" : "")">
                        <i class="fas fa-briefcase"></i><span> Thông tin tuyển dụng</span>
                    </a>
                </li>
            }

            <!-- Hướng dẫn đăng ký -->
            @if (Can(StaffPerms.Guides))
            {
                <li>
                    <a asp-area="Admin" asp-controller="Guides" asp-action="Index"
                       class="@(currentController == "Guides" ? "active" : "")">
                        <i class="fas fa-book-open"></i><span> Hướng dẫn đăng ký</span>
                    </a>
                </li>
            }

            <!-- Chức danh dự tuyển -->
            @if (Can(StaffPerms.Titles))
            {
                <li>
                    <a asp-area="Admin" asp-controller="Titles" asp-action="Index"
                       class="@(currentController == "Titles" ? "active" : "")">
                        <i class="fas fa-id-badge"></i><span> Chức danh dự tuyển</span>
                    </a>
                </li>
            }

            <!-- Vị trí dự tuyển -->
            @if (Can(StaffPerms.Positions))
            {
                <li>
                    <a asp-area="Admin" asp-controller="Positions" asp-action="Index"
                       class="@(currentController == "Positions" ? "active" : "")">
                        <i class="fas fa-tasks"></i><span> Vị trí dự tuyển</span>
                    </a>
                </li>
            }

            <!-- Khoa phòng-->
            @if (Can(StaffPerms.Departments))
            {
                <!-- 1) Danh mục khoa/phòng -->
                <li>
                    <a asp-area="Admin"
                       asp-controller="Departments"
                       asp-action="Index"
                       asp-route-tab="manage"
                       class="@(currentController == "Departments" && (string.IsNullOrEmpty(currentTab) || currentTab == "manage") ? "active" : "")">
                        <i class="fas fa-building"></i><span> Khoa phòng</span>
                    </a>
                </li>

                <!-- 2) Thiết lập vị trí -->
                <li>
                    <a asp-area="Admin"
                       asp-controller="Departments"
                       asp-action="Index"
                       asp-route-tab="map"
                       class="@(currentController == "Departments" && currentTab == "map" ? "active" : "")">
                        <i class="fas fa-sitemap"></i><span> Thiết lập vị trí </span>
                    </a>
                </li>
            }

            <!-- Báo cáo thống kê -->
            @if (Can(StaffPerms.Reports))
            {
                <li>
                    <a asp-area="Admin" asp-controller="Reports" asp-action="Index"
                       class="@(currentController == "Reports" ? "active" : "")">
                        <i class="fas fa-chart-bar"></i><span> Báo cáo thống kê</span>
                    </a>
                </li>
            }
        </ul>
    </div>

    <!-- Main content -->
    <div class="main" id="main">
        <div class="topbar">
            <div class="d-flex align-items-center">
                <div class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </div>
                <form id="admin-global-search" class="search-box" action="#" method="get" autocomplete="off">
                    <i class="fas fa-search"></i>
                    <input type="text" id="globalSearchInput" name="q" placeholder="Tìm kiếm..." />
                </form>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="dropdown profile">
                    <a class="d-flex align-items-center text-decoration-none dropdown-toggle profile-name" href="#"
                       role="button" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="~/images/avtAD.jpg" alt="Avatar" width="32" height="32">
                        <div class="name-role">
                            <span class="name">@username</span>
                            <span class="role">@roleDisplay</span>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="dropdownUser">
                        <li>
                            <a class="dropdown-item" asp-area="Admin" asp-controller="Account" asp-action="Profile">
                                <i class="fas fa-user-circle me-2 text-primary"></i> Quản lý tài khoản
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               asp-area="Admin" asp-controller="Account" asp-action="ChangePassword">
                                <i class="fas fa-key me-2 text-danger"></i> Đổi mật khẩu
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a class="dropdown-item"
                               href="@Url.Action("Logout", "Account", new { area = "Admin" })">
                                <i class="fas fa-sign-out-alt me-2 text-warning"></i> Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a asp-area="Admin" asp-controller="Account" asp-action="Login" class="btn btn-light">Đăng nhập</a>
            }
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.getElementById('main').classList.toggle('collapsed');
        }
    </script>

    <script>
        (function ($) {
          if (!$.validator) return;
          $.validator.addMethod('datenotfuture', function (value, element) {
            if (!value) return true;
            var input = new Date(value);
            var today = new Date(); today.setHours(0,0,0,0);
            return input <= today;
          });
          $.validator.unobtrusive.adapters.addBool('datenotfuture');
        })(jQuery);
    </script>

    <script>
        (function () {
          const form = document.getElementById('admin-global-search');
          const input = document.getElementById('globalSearchInput');
          if (!form || !input) return;

          form.addEventListener('submit', function (e) {
            e.preventDefault();
            const q = (input.value || '').trim();
            if (!q) return;

            const url = '@Url.Action("Go", "Search", new { area = "Admin" })' + '?q=' + encodeURIComponent(q);
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
              .then(async resp => {
                if (resp.ok) {
                  const data = await resp.json();
                  if (data && data.url) {
                    window.location.assign(data.url);
                    return;
                  }
                }
                showNotFoundToast();
              })
              .catch(showNotFoundToast);
          });

          function showNotFoundToast() {
            const el = document.getElementById('searchToast');
            if (el && window.bootstrap) {
              new bootstrap.Toast(el).show();
            } else {
              alert('Không tìm thấy kết quả phù hợp.');
            }
          }
        })();
    </script>

    @RenderSection("Scripts", required: false)

    <!-- Toast thông báo -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:2000">
        <div id="searchToast" class="toast align-items-center text-bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">Không tìm thấy kết quả phù hợp.</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

</body>
</html>
