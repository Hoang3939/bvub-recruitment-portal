@model BVUB_WebTuyenDung.Areas.Admin.Controllers.AccountController.ResetPasswordVm
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Areas/Admin/Views/Shared/_AuthLayout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-sm-10 col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h3 class="mb-3">Đặt lại mật khẩu</h3>

                    @if (Model?.Done == true)
                    {
                            <div class="alert alert-success">
                                Mật khẩu đã được cập nhật. Bạn có thể
                                <a asp-area="Admin" asp-controller="Account" asp-action="Login">đăng nhập</a> ngay bây giờ.
                            </div>
                    }
                    else
                    {
                            <form method="post" asp-area="Admin" asp-controller="Account" asp-action="ResetPassword" autocomplete="off">
                            @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="Token" />

                                <div class="mb-3">
                                    <label class="form-label">Mật khẩu mới</label>
                                    <input type="password" asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Xác nhận mật khẩu mới</label>
                                    <input type="password" asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>

                                <button class="btn btn-primary">Cập nhật mật khẩu</button>
                                <a class="btn btn-link" asp-area="Admin" asp-controller="Account" asp-action="Login">Hủy</a>
                            </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}
