@model BVUB_WebTuyenDung.Areas.Admin.Controllers.AccountController.ResetPasswordVm
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Areas/Admin/Views/Shared/_AuthLayout.cshtml";
}

<link rel="stylesheet" href="~/css/admin-pass.css" asp-append-version="true" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-sm-10 col-md-8 col-lg-6">
            <div class="card shadow-sm login-card">
                <div class="card-body p-4">

                    <div class="title-row">
                        <!-- icon khoá (SVG) để không phụ thuộc lib khác -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="11" width="18" height="10" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        <h3 class="m-0">Đặt lại mật khẩu</h3>
                    </div>

                    <p class="desc">Nhập mật khẩu mới cho tài khoản của bạn.</p>

                    @if (Model?.Done == true)
                    {
                        <div class="alert alert-success">
                            Mật khẩu đã được cập nhật. Bạn có thể
                            <a asp-area="Admin" asp-controller="Account" asp-action="Login">đăng nhập</a> ngay bây giờ.
                        </div>
                    }
                    else
                    {
                        <form method="post"
                              asp-area="Admin"
                              asp-controller="Account"
                              asp-action="ResetPassword"
                              autocomplete="off">

                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Token" />

                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                            <div class="mb-3">
                                <label class="form-label">Mật khẩu mới</label>
                                <input type="password" asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="NewPassword" class="text-danger"></span>
                                <div class="note">Mật khẩu tối thiểu 6 ký tự.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Xác nhận mật khẩu mới</label>
                                <input type="password" asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <div class="actions">
                                <button class="btn btn-primary" type="submit">Cập nhật mật khẩu</button>
                                <a class="btn btn-link" asp-area="Admin" asp-controller="Account" asp-action="Login">Hủy</a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
