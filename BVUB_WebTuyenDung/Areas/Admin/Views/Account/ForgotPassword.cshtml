@model BVUB_WebTuyenDung.Areas.Admin.Controllers.AccountController.ForgotPasswordVm
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Areas/Admin/Views/Shared/_AuthLayout.cshtml";
}

<!-- Có thể giữ block <style> này hoặc tách sang /css riêng; không có JS nên OK -->
<style>
    .login-card .title-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 6px;
    }

    .login-card .desc {
        font-size: 13px;
        text-align: center;
        opacity: .8;
        margin-bottom: 18px;
    }

    .login-card .note {
        font-size: 12px;
        opacity: .7;
        margin-top: 8px;
    }

    .login-card .actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }
</style>

<div class="login-bg">
    <div class="circle-1"></div><div class="circle-2"></div><div class="circle-3"></div><div class="circle-4"></div>
</div>

<div class="login-card" style="max-width: 460px;">
    <div class="title-row">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4880FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16v16H4z"></path>
            <path d="m22 6-10 7L2 6"></path>
        </svg>
        <h2 style="margin:0;">QUÊN MẬT KHẨU</h2>
    </div>

    <p class="desc">Nhập <b>Tên đăng nhập</b> hoặc <b>Email</b> để nhận liên kết đặt lại mật khẩu.</p>

    @if (Model?.Sent == true)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="font-size:14px;">
            Nếu email/tài khoản tồn tại, chúng tôi đã gửi liên kết đặt lại mật khẩu. Vui lòng kiểm tra hộp thư.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <div class="actions">
            <a class="btn btn-primary" asp-area="Admin" asp-controller="Account" asp-action="Login">Quay lại đăng nhập</a>
        </div>
    }
    else
    {
        <form method="post" asp-area="Admin" asp-controller="Account" asp-action="ForgotPassword" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:8px;"></div>

            <label class="form-label">Tên đăng nhập hoặc Email</label>
            <input asp-for="Login" class="form-control" autocomplete="username email" />
            <span asp-validation-for="Login" class="text-danger" style="font-size:12px;"></span>

            <div class="note">Mẹo: nhớ kiểm tra mục <i>Spam/Quảng cáo</i> nếu không thấy email trong Hộp thư đến.</div>

            <div class="actions" style="margin-top:14px;">
                <button class="btn btn-primary" type="submit">Gửi liên kết đặt lại</button>
                <a class="btn btn-link" asp-area="Admin" asp-controller="Account" asp-action="Login">Quay lại đăng nhập</a>
            </div>
        </form>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
