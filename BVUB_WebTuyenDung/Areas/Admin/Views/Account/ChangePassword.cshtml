@model BVUB_WebTuyenDung.Areas.Admin.Controllers.AccountController.ChangePasswordVm
@{
    ViewData["Title"] = "Đổi mật khẩu";
}
<h3>Đổi mật khẩu</h3>

@if (!string.IsNullOrEmpty(Model?.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="post" asp-area="Admin" asp-controller="Account" asp-action="ChangePassword" autocomplete="off">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Mật khẩu hiện tại</label>
        <input type="password" asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Mật khẩu mới</label>
        <input type="password" asp-for="NewPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Xác nhận mật khẩu mới</label>
        <input type="password" asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>
    <button class="btn btn-primary">Cập nhật</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
