@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Areas/Admin/Views/Shared/_AuthLayout.cshtml";
}
<div class="login-bg">
    <div class="circle-1"></div>
    <div class="circle-2"></div>
    <div class="circle-3"></div>
    <div class="circle-4"></div>
</div>

<div class="login-card">
    <h2>ĐĂNG NHẬP</h2>
    <p>Vui lòng nhập Email và mật khẩu để tiếp tục</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post" autocomplete="on">
        @Html.AntiForgeryToken()

        <label class="form-label">Tên đăng nhập hoặc Email:</label>
        <input type="text" name="username" class="form-control" autocomplete="username" required />

        <div class="form-footer">
            <label class="form-label">Mật khẩu:</label>
            @if (ViewBag.ShowForgot == true)
            {
                <a asp-area="Admin" asp-controller="Account" asp-action="ForgotPassword">Quên mật khẩu?</a>
            }
            else
            {
                <span style="opacity:0;">Quên mật khẩu?</span>
            }
        </div>

        <div class="password-group">
            <input type="password" id="passwordInput" name="password" class="form-control" autocomplete="current-password" required />
            <button type="button" class="toggle-password" aria-label="Hiện/ẩn mật khẩu" aria-pressed="false" data-state="hide">
                <svg class="icon-eye" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z" />
                    <circle cx="12" cy="12" r="3" />
                </svg>
                <svg class="icon-eye-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-7 0-11-7-11-7a20.29 20.29 0 0 1 5.06-5.94M9.9 4.24A10.94 10.94 0 0 1 12 5c7 0 11 7 11 7a20.24 20.24 0 0 1-4.27 5.15" />
                    <line x1="1" y1="1" x2="23" y2="23" />
                </svg>
            </button>
        </div>

        <div class="remember-row">
            <input type="checkbox" id="rememberMe" name="rememberMe" value="true" />
            <label for="rememberMe">Ghi nhớ đăng nhập</label>
        </div>

        <button type="submit" class="login-btn">Đăng Nhập</button>
    </form>
</div>

@section Scripts {
    <script src="~/js/pages/account.login.js" asp-append-version="true"></script>
}
