@model BVUB_WebTuyenDung.Areas.Admin.Models.HuongDanDangKy

<div>
    <h4 style="margin:0 0 8px 0; font-weight:800;">@Model.TieuDe</h4>

    <div style="color:#475569; margin-bottom:12px;">
        <b>Loại:</b> @Model.LoaiHuongDan
        <br />
        <b>Cập nhật:</b> @Model.NgayCapNhat.ToString("dd/MM/yyyy")
    </div>

    <div style="font-weight:700; margin:6px 0 8px;">Nội dung:</div>
    <div style="line-height:1.6; color:#334155;">
        @Html.Raw(Model.NoiDung)   <!-- hiển thị rich content từ CKEditor -->
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.FileHuongDan))
    {
        <div style="margin-top:12px;">
            <b>Đính kèm:</b>
            <a href="@Model.FileHuongDan" target="_blank" rel="noopener">Mở tệp</a>
        </div>
    }
</div>
