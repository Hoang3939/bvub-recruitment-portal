@model BVUB_WebTuyenDung.Areas.Admin.Models.HuongDanDangKy
@{
    ViewData["Title"] = "Thêm hướng dẫn";
}
<div class="header-row"><h2>@ViewData["Title"]</h2></div>

<link rel="stylesheet" href="~/css/admin-guides-index.css" asp-append-version="true" />

<div class="main-content">
    <form asp-action="Create" method="post" id="guideCreateForm">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="TieuDe" class="form-label">Tiêu đề</label>
            <input asp-for="TieuDe" class="form-control" />
            <span asp-validation-for="TieuDe" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="LoaiHuongDan" class="form-label">Loại hướng dẫn</label>
            <select asp-for="LoaiHuongDan" class="form-select">
                <option>Người lao động</option>
                <option>Viên chức</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Nội dung</label>
            <div id="toolbar-container"></div>
            <div id="editor" class="form-control" style="min-height:400px"></div>
            <input type="hidden" id="NoiDung" name="NoiDung" />
            <div class="form-text">Bạn có thể dán ảnh, kéo thả ảnh, hoặc dùng nút “Chèn ảnh từ thư viện”.</div>
        </div>

        <div class="mb-3">
            <label asp-for="FileHuongDan" class="form-label">File hướng dẫn</label>
            <input asp-for="FileHuongDan" class="form-control" />
        </div>

        <div class="actions" style="margin-top:10px;">
            <button class="btn btn-primary">Lưu</button>
            <a asp-action="Index" class="btn btn-light">Huỷ</a>
            <button type="button" class="btn btn-export" data-bs-toggle="modal" data-bs-target="#mediaModal">
                Chèn ảnh từ thư viện
            </button>
        </div>
    </form>
</div>

<!-- Modal: Thư viện ảnh -->
<div class="modal fade" id="mediaModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thư viện ảnh</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="mediaGrid" class="row g-2"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.2.1/decoupled-document/ckeditor.js"></script>
    <script src="~/js/pages/admin.guides.create.js" asp-append-version="true"></script>
}
