@model BVUB_WebTuyenDung.Areas.Admin.Models.HuongDanDangKy
@{
    ViewData["Title"] = "Sửa hướng dẫn";
}
<div class="header-row"><h2>@ViewData["Title"]</h2></div>
<div class="main-content">
    
    <form asp-action="Edit" method="post" id="guideEditForm" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="HuongDanId" />

        <div class="mb-3">
            <label asp-for="TieuDe" class="form-label">Tiêu đề</label>
            <input asp-for="TieuDe" class="form-control" />
            <span asp-validation-for="TieuDe" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="LoaiHuongDan" class="form-label">Loại hướng dẫn</label>
            <select asp-for="LoaiHuongDan" class="form-select">
                <option>Người lao động</option>
                <option>Viên chức</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Nội dung</label>
            <div id="toolbar-container"></div>
            <div id="editor" class="form-control" style="min-height:400px">@Html.Raw(Model.NoiDung)</div>
            <input type="hidden" id="NoiDung" name="NoiDung" />
        </div>

        <div class="mb-3">
            <label class="form-label">File hướng dẫn</label>
            <input type="file" name="file" class="form-control" />
            @if (!string.IsNullOrWhiteSpace(Model?.FileHuongDan))
            {
                <div class="form-text">
                    Tệp hiện tại:
                    <a href="@Model.FileHuongDan" target="_blank" rel="noopener">
                        @System.IO.Path.GetFileName(Model.FileHuongDan)
                    </a> — Chọn tệp mới để thay thế.
                </div>
            }
        </div>

        <button class="btn btn-primary">Lưu</button>
        <a asp-action="Index" class="btn btn-light">Huỷ</a>
        <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#mediaModal">Chèn ảnh từ thư viện</button>
    </form>
</div>

<!-- Modal -->
<div class="modal fade" id="mediaModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thư viện ảnh</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="mediaGrid" class="row g-2"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.2.1/decoupled-document/ckeditor.js"></script>
    <script src="~/js/pages/admin.guides.edit.js" asp-append-version="true"></script>
}
