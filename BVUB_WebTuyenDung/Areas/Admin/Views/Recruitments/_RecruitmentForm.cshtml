@model BVUB_WebTuyenDung.Areas.Admin.Models.ThongTinTuyenDung

<link rel="stylesheet" href="~/css/admin-recruitments-index.css" asp-append-version="true" />

<div class="rec-form-grid">
    <div class="full">
        <label asp-for="TieuDe" class="form-label">Tiêu đề</label>
        <input asp-for="TieuDe" class="form-control" />
        <span asp-validation-for="TieuDe" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="LoaiTuyenDung" class="form-label">Loại tuyển dụng</label>
        <select asp-for="LoaiTuyenDung" class="form-select">
            <option value="">-- Chọn loại tuyển dụng --</option>
            <option value="Người lao động">Người lao động</option>
            <option value="Viên chức">Viên chức</option>
        </select>
        <span asp-validation-for="LoaiTuyenDung" class="text-danger"></span>
    </div>


    <div>
        <label asp-for="TrangThai" class="form-label">Trạng thái</label>
        <select asp-for="TrangThai" class="form-select"
                asp-items="Html.GetEnumSelectList<TrangThaiTuyenDung>()"></select>
        <span asp-validation-for="TrangThai" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="NgayDang" class="form-label">Ngày đăng</label>
        <input asp-for="NgayDang" type="date" class="form-control" />
        <span asp-validation-for="NgayDang" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="HanNopHoSo" class="form-label">Hạn nộp hồ sơ</label>
        <input asp-for="HanNopHoSo" type="date" class="form-control" />
        <span asp-validation-for="HanNopHoSo" class="text-danger"></span>
    </div>

    <div class="full">
        <label asp-for="NoiDung" class="form-label">Nội dung</label>
        <textarea asp-for="NoiDung" class="form-control"></textarea>
        <span asp-validation-for="NoiDung" class="text-danger"></span>
    </div>

    <!-- Đính kèm -->
    <div class="full">
        <label class="form-label">File đính kèm</label>
        <input type="file" name="file" class="form-control" />
        @if (!string.IsNullOrWhiteSpace(Model?.FileDinhKem))
        {
            <div class="form-text">
                Tệp hiện tại:
                <a href="@Model.FileDinhKem" target="_blank" rel="noopener">
                    @System.IO.Path.GetFileName(Model.FileDinhKem)
                </a> — Chọn tệp mới để thay thế.
            </div>
        }
    </div>

    <!-- Ảnh hiển thị -->
    <div class="full">
        <label class="form-label">Ảnh hiển thị</label>
        <input type="file" name="image" accept="image/*" class="form-control" />
        @if (!string.IsNullOrWhiteSpace(Model?.FileAnh))
        {
            <div class="form-text" style="display:flex;align-items:center;gap:12px;margin-top:6px;">
                <span>Ảnh hiện tại:</span>
                <img src="@Model.FileAnh" alt="Ảnh hiện tại" style="height:56px;border-radius:10px;border:1px solid #e5e7eb;object-fit:cover;" />
                <span>(Chọn ảnh mới để thay thế)</span>
            </div>
        }
    </div>
</div>
