@model BVUB_WebTuyenDung.Areas.Admin.Models.DanhMucChucDanhDuTuyen

<div class="detail-grid">
    <div><b>Mã chức danh:</b> @Model.ChucDanhId</div>
    <div><b>Tên chức danh:</b> @Model.TenChucDanh</div>
    <div>
        <b>Trạng thái:</b>
        <span class="status @(Model.TamNgung == 1 ? "cancelled" : "approved")">
            @(Model.TamNgung == 1 ? "Tạm ngưng" : "Sử dụng")
        </span>
    </div>
</div>

<div class="modal-footer" style="margin-top:12px">
    <a class="btn btn-primary"
       asp-area="Admin" asp-controller="Titles" asp-action="Edit"
       asp-route-id="@Model.ChucDanhId">Sửa</a>
</div>

<style>
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }
    @@media(max - width:700px) {
        .detail-grid

    {
        grid-template-columns: 1fr;
    }

    }
</style>
