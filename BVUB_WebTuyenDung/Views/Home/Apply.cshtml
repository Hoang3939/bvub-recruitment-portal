@{
    ViewData["Title"] = "Đăng ký ứng tuyển";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .apply-container {
        max-width: 700px;
        margin: 50px auto;
        padding: 0 20px;
        font-family: Arial, sans-serif;
    }

        .apply-container h2 {
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 40px;
        }

    .job-option {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #ccc;
        padding: 20px 0;
    }

        .job-option:first-child {
            border-top: none;
        }

    .job-label {
        font-size: 18px;
        color: #000;
    }

    .apply-button {
        background-color: #4475B9;
        color: white;
        font-size: 14px;
        font-weight: bold;
        border: none;
        border-radius: 7000px;
        padding: 10px 20px;
        text-decoration: none;
    }

        .apply-button:hover {
            background-color: #365a96;
        }
</style>

<div class="apply-container">
    <h2>Đăng ký tuyển dụng vào Bệnh viện Ung Bướu TPHCM</h2>

    <div class="job-option">
        <div class="job-label">Viên chức</div>
        <a href="@Url.Action("VienChuc", "DangKy")" class="apply-button">ĐĂNG KÝ ỨNG TUYỂN</a>
    </div>

    <div class="job-option">
        <div class="job-label">Người lao động</div>
        <a href="@Url.Action("NguoiLaoDong", "DangKy")" class="apply-button">ĐĂNG KÝ ỨNG TUYỂN</a>
    </div>
</div>
