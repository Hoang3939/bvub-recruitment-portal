@{
    ViewData["Title"] = "Tra cứu thông tin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .search-container {
        max-width: 600px;
        margin: 40px auto;
        text-align: center;
    }

        .search-container h2 {
            color: #4475B9;
            margin-bottom: 30px;
        }

        .search-container form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .search-container input[type="text"],
        .search-container input[type="email"] {
            padding: 12px 16px;
            font-size: 16px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

    .captcha-group {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .captcha-placeholder {
        width: 120px;
        height: 40px;
        background-color: #eee;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    .search-container button {
        background-color: #4475B9;
        color: white;
        font-size: 18px;
        font-weight: bold;
        border: none;
        border-radius: 7000px;
        padding: 15px 30px;
        cursor: pointer;
        margin-top: 10px;
    }

        .search-container button:hover {
            background-color: #365a96;
        }
</style>

<div class="search-container">
    <h2>TRA CỨU THÔNG TIN</h2>

    <form method="post" asp-action="Index">
        <input type="text" name="maPhieu" placeholder="Mã phiếu đăng ký" required />
        <input type="text" name="emailOrCccdOrSdt" placeholder="Email / CCCD / SĐT" required />

        <div class="captcha-group">
            <input type="text" name="captcha" placeholder="Mã bảo vệ" required />
            <div class="captcha-placeholder">
                <!-- Captcha giả lập -->
            </div>
        </div>

        <button type="submit">TRA CỨU</button>
    </form>
</div>
