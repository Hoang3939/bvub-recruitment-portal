@model BVUB_WebTuyenDung.Controllers.TraCuuViewModel
@{
    ViewData["Title"] = "Tra cứu thông tin";
}

@section Styles {
    <link rel="stylesheet" href="~/css/tracuu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/huongdan.css" asp-append-version="true" />
}

<div class="tracuu-wrap">
    <h1 class="hd-title">Tra cứu đơn ứng tuyển</h1>

    <form asp-action="Index" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger" aria-live="polite"></div>

        <!-- Select + Input định danh (1 dòng) -->
        <div class="form-group">
            <label for="selectDinhDanh" class="form-label">Thông tin định danh</label>
            <div class="tracuu-inline">
                <select asp-for="DinhDanh" id="selectDinhDanh" class="tracuu-select" aria-describedby="hintDinhDanh">
                    <option value="CCCD">CCCD</option>
                    <option value="Gmail">Gmail</option>
                    <option value="SDT">Số điện thoại</option>
                </select>

                <input asp-for="GiaTri"
                       id="inputGiaTri"
                       class="tracuu-input"
                       inputmode="text"
                       autocomplete="off"
                       placeholder="Nhập CCCD"
                       aria-describedby="hintDinhDanh" />
            </div>
            <span asp-validation-for="GiaTri" class="text-danger"></span>
        </div>

        <!-- Mã tra cứu -->
        <div class="form-group">
            <label asp-for="MaTraCuu" class="form-label">Mã tra cứu</label>
            <input asp-for="MaTraCuu"
                   class="tracuu-input"
                   autocomplete="off"
                   placeholder="Nhập mã tra cứu" />
            <span asp-validation-for="MaTraCuu" class="text-danger"></span>
        </div>

        <!-- Captcha: input + ảnh + nút (1 dòng) -->
        <div class="form-group">
            <label asp-for="CaptchaInput" class="form-label">Mã Captcha</label>
            <div class="captcha-line">
                <input asp-for="CaptchaInput"
                       class="captcha-input"
                       autocomplete="off"
                       placeholder="Nhập ký tự trong ảnh"
                       aria-describedby="captchaHelp" />

                <img id="captcha-img"
                     class="captcha-img"
                     src="@Url.Action("Captcha", "TraCuu")?ts=@DateTimeOffset.Now.ToUnixTimeSeconds()"
                     alt="Mã Captcha" />

                <button type="button" id="btn-refresh" class="btn-refresh" aria-label="Đổi mã Captcha">Đổi mã</button>
            </div>
            <span asp-validation-for="CaptchaInput" class="text-danger"></span>
        </div>

        <!-- Nút tra cứu -->
        <div class="tracuu-actions">
            <button type="submit" class="btn-primary">Tra cứu</button>
        </div>
    </form>
</div>

<!-- Kết quả -->
@if (Model?.KetQua != null && Model.KetQua.Count > 0)
{
    <div class="tracuu-result" aria-live="polite">
        @foreach (var r in Model.KetQua)
        {
            <div class="tracuu-card">
                <div>
                    <h5>@r.TenDon</h5>
                    <p><strong>Trạng thái:</strong> @r.TrangThai</p>
                </div>
                <div>
                    <a asp-action="Details"
                       asp-route-loai="@r.Loai"
                       asp-route-id="@r.Id"
                       class="btn-detail">Xem chi tiết</a>
                </div>
            </div>
        }
    </div>
}
else if (Context.Request.Method == "POST" && ViewData.ModelState.ErrorCount == 0)
{
    <div class="tracuu-result" aria-live="polite">
        <div class="tracuu-card"><div>Không tìm thấy kết quả phù hợp.</div></div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const sel = document.getElementById('selectDinhDanh');
            const input = document.getElementById('inputGiaTri');

            function sync() {
                switch (sel.value) {
                    case 'CCCD':
                        input.placeholder = 'Nhập CCCD';
                        input.type = 'text';
                        input.inputMode = 'numeric';
                        break;
                    case 'Gmail':
                        input.placeholder = 'Nhập Gmail';
                        input.type = 'email';
                        input.inputMode = 'email';
                        break;
                    default: // SDT
                        input.placeholder = 'Nhập số điện thoại';
                        input.type = 'tel';
                        input.inputMode = 'tel';
                        break;
                }
            }

            if (sel && input) {
                sel.addEventListener('change', sync);
                sync();
            }

            const btnRefresh = document.getElementById('btn-refresh');
            const img = document.getElementById('captcha-img');
            if (btnRefresh && img) {
                btnRefresh.addEventListener('click', function () {
                    img.src = '@Url.Action("Captcha", "TraCuu")' + '?ts=' + Date.now();
                });
            }
        })();
    </script>
}