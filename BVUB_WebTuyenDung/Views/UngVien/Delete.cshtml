@model BVUB_WebTuyenDung.Models.UngVien

@{
    ViewData["Title"] = "Xoá Ứng Viên";
}

<h2>@ViewData["Title"]</h2>

<h4>Bạn có chắc chắn muốn xoá ứng viên này?</h4>
<hr />
<dl class="row">
    <dt class="col-sm-3">Họ tên</dt>
    <dd class="col-sm-9">@Model.HoTen</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="UngVienId" />
    <button type="submit" class="btn btn-danger">Xoá</button>
    <a asp-action="Index" class="btn btn-secondary">Huỷ</a>
</form>