@* Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - BV Ung Bướu</title>

    <!-- CSS chung của site -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- CSS của layout (đã tách) -->
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    @* CSS riêng từng trang (ví dụ: apply-forms.css chỉ cho 2 form) *@
    @RenderSection("Styles", required: false)

    @* Flatpickr CSS (nếu dùng datepicker dd/MM/yyyy) *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
</head>
<body>
    <div class="header">
        <img src="~/images/logo.png" alt="Logo" />
        <h1>Bệnh viện Ung Bướu<br /><small>Thành phố Hồ Chí Minh</small></h1>
    </div>

    <div class="nav">
        <div>Thông tin tuyển dụng</div>
        <div>Hướng dẫn đăng ký</div>
        <div>Tra cứu thông tin</div>
    </div>

    <div class="page-wrapper">
        <div class="content-wrapper">
            @RenderBody()
        </div>

        @{
            var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
            var hideFooterActions = new[] { "VienChuc", "NguoiLaoDong" };
            var showFooter = !hideFooterActions.Contains(currentAction);
        }
        @if (showFooter)
        {
            <footer>
                <div class="info">
                    <div class="info-block">
                        <strong>Bệnh viện Ung Bướu TPHCM</strong><br />
                        <strong>Cơ sở 1:</strong> Số 47 Nguyễn Huy Lượng, P. Bình Thạnh, TP. HCM<br />
                        Số 6 Nguyễn Huy Lượng, P. Bình Thạnh, TP. HCM<br />
                        <strong>Cơ sở 2:</strong> Số 12 Đường 400, Phường Tăng Nhơn Phú, TP. HCM
                    </div>

                    <div class="info-block">
                        <div class="info-line"><strong>Email:</strong> <span>bvubhcm@gmail.com</span></div>
                        <div class="info-line"><strong>Chăm sóc khách hàng:</strong> <span>1900636223</span></div>
                        <div class="info-line"><strong>Cơ sở 1:</strong> <span>(028) 38433022</span></div>
                        <div class="info-line"><strong>Cơ sở 2:</strong> <span>(028) 36227722 – (028) 38433021</span></div>
                        <div class="info-line"><strong>Góp ý phản ánh BV Ung bướu:</strong> <span>0967981010</span></div>
                        <div class="info-line"><strong>Góp ý phản ánh Sở y tế:</strong> <span>0967771010</span></div>
                        <div class="info-line"><strong>Góp ý phản ánh Bộ y tế:</strong> <span>19009095</span></div>
                    </div>
                </div>
            </footer>
        }
    </div>

    <!-- JS chung -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>

    @* Flatpickr JS + locale Việt (nếu dùng datepicker dd/MM/yyyy trong layout.js) *@
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>

    <!-- JS của layout (đã tách) -->
    <script src="~/js/layout.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
