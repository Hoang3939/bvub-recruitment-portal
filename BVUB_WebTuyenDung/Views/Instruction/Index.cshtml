@model dynamic

@{
    ViewData["Title"] = "Hướng dẫn đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
        }

        .content {
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .guide-title {
            text-align: center;
            color: #4475B9;
            font-size: 29.5px;
            font-family: Inter;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .step {
            margin-bottom: 20px;
        }

        .step-title {
            color: black;
            font-size: 22.5px;
            font-family: Inter;
            font-weight: 700;
        }

        .step-subtitle {
            color: black;
            font-size: 22.5px;
            font-family: Inter;
            font-style: italic;
            font-weight: 300;
        }

        .toggle-buttons {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .toggle-button {
            background-color: #F6F2F2;
            color: #A8A7A7;
            font-size: 20px;
            font-family: Inter;
            font-weight: 500;
            padding: 7px 14px;
            border: 1px solid #A8A7A7;
            border-radius: 10px;
            cursor: pointer;
            box-shadow: 0px 2.8px 2.8px rgba(0, 0, 0, 0.25);
            border-top-left-radius: 10px;
            border-bottom-left-radius: 10px;
        }

            .toggle-button.active {
                background-color: #4475B9;
                color: white;
                box-shadow: none;
            }

        .center-container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .apply-button {
            background-color: #4475B9;
            color: white;
            font-size: 20px;
            font-family: Inter;
            font-weight: 700;
            border-radius: 7000px;
            padding: 15px 30px;
            text-align: center;
            display: inline-block;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="content">
        <div class="guide-title">HƯỚNG DẪN ĐĂNG KÝ - CẬP NHẬT THÔNG TIN ỨNG VIÊN</div>
        <div class="toggle-buttons">
            <div class="toggle-button active" onclick="toggleGuide('vienchuc')">Viên chức</div>
            <div class="toggle-button" onclick="toggleGuide('nguoilaodong')">Người lao động</div>
        </div>
        <div class="step" id="guide-content">
            <div class="step-subtitle">(Phiên bản dành cho Viên chức)</div>
            <!-- Add more steps or form content here as needed -->
            <div class="center-container">
                <a href="#" class="apply-button">ĐĂNG KÝ ỨNG TUYỂN</a>
            </div>

            <script>
                function toggleGuide(type) {
                    const content = document.getElementById('guide-content');
                    const buttons = document.querySelectorAll('.toggle-button');
                    buttons.forEach(btn => btn.classList.remove('active'));

                    if (type === 'vienchuc') {
                        content.innerHTML = '<div class="step-subtitle">(Phiên bản dành cho Viên chức)</div>';
                        buttons[0].classList.add('active');
                    } else {
                        content.innerHTML = '<div class="step-subtitle">(Phiên bản dành cho Người lao động)</div>';
                        buttons[1].classList.add('active');
                    }
                }
            </script>
</body>
</html>