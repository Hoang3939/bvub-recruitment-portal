@{
    ViewBag.Title = "Hướng dẫn đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .huongdan-container {
        width: 100%;
        position: relative;
        background: white;
        overflow: hidden;
        min-height: 3400px;
        font-family: 'Inter', sans-serif;
    }

    .huongdan-title {
        max-width: 1353px;
        margin: 60px auto 0;
        text-align: center;
        color: #4475B9;
        font-size: 45px;
        font-weight: 700;
    }

    .sidebar {
        position: absolute;
        left: 66px;
        top: 483px;
    }

    .sidebar-box {
        width: 428px;
        height: 110px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 4px rgba(0,0,0,0.25);
        border-radius: 20px 0 0 20px;
        font-size: 40px;
        font-weight: 500;
    }

        .sidebar-box.active {
            background: #4475B9;
            color: white;
        }

        .sidebar-box.inactive {
            background: #F6F2F2;
            color: #A8A7A7;
            margin-top: 10px;
        }

    .main-box {
        margin-left: 494px;
        margin-top: 483px;
        background: white;
        border: 1px solid #A8A7A7;
        border-radius: 0 20px 20px 20px;
        width: 1161px;
        min-height: 2331px;
        padding: 40px;
    }

        .main-box .subtitle {
            font-size: 35px;
            font-style: italic;
            font-weight: 300;
            color: black;
        }

        .main-box .step {
            margin-top: 20px;
            font-size: 35px;
            font-weight: 700;
            color: black;
        }

    .register-button-wrapper {
        position: absolute;
        right: 100px;
        top: 2655px;
    }

    .register-button-bg {
        width: 511px;
        height: 97px;
        background: #4475B9;
        border-radius: 10000px;
    }

    .register-button-text {
        width: 506px;
        height: 111px;
        position: absolute;
        top: 27px;
        left: 0;
        text-align: center;
        color: white;
        font-size: 40px;
        font-weight: 700;
    }
</style>

<div class="huongdan-container">
    <!-- Tiêu đề -->
    <div class="huongdan-title">
        HƯỚNG DẪN ĐĂNG KÝ - CẬP NHẬT THÔNG TIN ỨNG VIÊN
    </div>

    <!-- Sidebar chọn đối tượng -->
    <div class="sidebar">
        <div class="sidebar-box active">Viên chức</div>
        <div class="sidebar-box inactive">Người lao động</div>
    </div>

    <!-- Khung nội dung chính -->
    <div class="main-box">
        <div class="subtitle">(Phiên bản dành cho Viên chức)</div>
        <div class="step">Bước 1:</div>
        <!-- Thêm nội dung các bước tiếp theo tại đây -->
    </div>

    <!-- Nút đăng ký -->
    <div class="register-button-wrapper">
        <div class="register-button-bg"></div>
        <div class="register-button-text">ĐĂNG KÝ ỨNG TUYỂN</div>
    </div>
</div>
