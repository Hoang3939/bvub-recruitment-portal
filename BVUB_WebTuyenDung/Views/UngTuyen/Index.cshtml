@{
    ViewData["Title"] = "Ứng tuyển vị trí";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container text-center my-5">
    <h2 class="title-center big-title">@ViewData["Title"]</h2>
    <p class="title-center big-subtitle">Vui lòng chọn loại đơn ứng tuyển</p>

    <div class="button-wrapper mt-4">
        <a asp-controller="UngTuyen" asp-action="VienChuc" class="btn btn-primary btn-lg">
            Ứng tuyển viên chức
        </a>
        <a asp-controller="UngTuyen" asp-action="NguoiLaoDong" class="btn btn-success btn-lg">
            Ứng tuyển người lao động
        </a>
    </div>

</div>

<style>
    .container {
        max-width: 800px;
        margin: 0 auto;
    }

    .title-center {
        text-align: center;
        width: 100%;
        margin-bottom: 1rem;
    }

    .big-title {
        font-size: 2.2rem;
        font-weight: bold;
    }

    .big-subtitle {
        font-size: 1.4rem;
        color: #555;
    }

    .button-wrapper {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .btn {
        font-size: 18px;
        padding: 12px 30px;
        border-radius: 8px;
        text-decoration: none !important;
        transition: 0.3s ease;
        display: inline-block;
    }

        .btn:hover {
            transform: scale(1.05);
            opacity: 0.9;
        }

    .btn-primary {
        background-color: #1e87f0;
        border: none;
        color: white;
    }

    .btn-success {
        background-color: #28a745;
        border: none;
        color: white;
    }
</style>
