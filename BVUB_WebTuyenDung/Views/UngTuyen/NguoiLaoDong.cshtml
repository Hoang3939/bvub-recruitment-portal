@model BVUB_WebTuyenDung.Models.UngTuyenNguoiLaoDongViewModel

@{
    ViewData["Title"] = "Ứng tuyển người lao động";
}

<form asp-action="UngTuyenNguoiLaoDong" method="post" class="form-card" data-mode="nld" novalidate>
    @Html.AntiForgeryToken()

    <h2 class="form-title">@ViewData["Title"]</h2>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <hr class="hr-soft" />
    <h4 class="section-title">Thông tin ứng viên</h4>

    <!-- Email -->
    <div class="form-group">
        <label asp-for="UngVien.Email" class="form-label">Email</label>
        <div class="inline-row">
            <input asp-for="UngVien.Email" class="form-control" id="txtEmail" placeholder="Ví dụ: abc@gmail.com"/>
            <button type="button" id="btnCheckEmail" class="btn btn-secondary">Kiểm tra</button>
        </div>
        <small id="emailHint" class="text-muted"></small>
        <span asp-validation-for="UngVien.Email" class="text-danger"></span>
    </div>


    <!-- Loại hồ sơ -->
    <div class="form-group">
        <label class="form-label">Loại hồ sơ</label>
        <select id="loaiHoSo" class="form-control">
            <option value="NguoiLaoDong" selected>Người lao động</option>
            <option value="VienChuc">Viên chức</option>
        </select>
    </div>

    <!-- Các trường Ứng viên -->
    <div class="form-group">
        <label asp-for="UngVien.HoTen" class="form-label">Họ và tên</label>
        <input asp-for="UngVien.HoTen" class="form-control" />
        <span asp-validation-for="UngVien.HoTen" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.GioiTinh" class="form-label">Giới tính</label>
        <select asp-for="UngVien.GioiTinh" class="form-control">
            <option value="0">Nam</option>
            <option value="1">Nữ</option>
        </select>
        <span asp-validation-for="UngVien.GioiTinh" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NgaySinh" class="form-label">Ngày tháng năm sinh</label>
        <input asp-for="UngVien.NgaySinh" class="form-control js-date" type="text" autocomplete="off" />
        <span asp-validation-for="UngVien.NgaySinh" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.SoDienThoai" class="form-label">Số điện thoại</label>
        <input asp-for="UngVien.SoDienThoai" class="form-control" />
        <span asp-validation-for="UngVien.SoDienThoai" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.CCCD" class="form-label">Số căn cước công dân hoặc căn cước</label>
        <input asp-for="UngVien.CCCD" class="form-control" maxlength="12" />
        <span asp-validation-for="UngVien.CCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NgayCapCCCD" class="form-label">Ngày cấp</label>
        <input asp-for="UngVien.NgayCapCCCD" class="form-control js-date" type="text" autocomplete="off" />
        <span asp-validation-for="UngVien.NgayCapCCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NoiCapCCCD" class="form-label">Nơi cấp Thẻ căn cước công dân hoặc thẻ căn cước</label>
        <select asp-for="UngVien.NoiCapCCCD" class="form-control">
            <option value="">-- Chọn nơi cấp --</option>
            <option value="Bộ Công an">Bộ Công an</option>
            <option value="Cục Cảnh sát quản lý hành chính về trật tự xã hội">Cục Cảnh sát quản lý hành chính về trật tự xã hội</option>
            <option value="Cục Cảnh sát đăng ký quản lý cư trú và dữ liệu Quốc gia về dân cư">Cục Cảnh sát đăng ký quản lý cư trú và dữ liệu Quốc gia về dân cư</option>
        </select>
        <span asp-validation-for="UngVien.NoiCapCCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.DiaChiThuongTru" class="form-label">Địa chỉ thường trú (ghi đầy đủ và chính xác theo thông tin trong ứng dụng VNeID)</label>
        <input asp-for="UngVien.DiaChiThuongTru" class="form-control" placeholder="Ví dụ: 59 Nguyễn Thị Minh Khai, phường Bến Thành, Thành phố Hồ Chí Minh" />
        <span asp-validation-for="UngVien.DiaChiThuongTru" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.DiaChiCuTru" class="form-label">Địa chỉ nơi cư trú (để báo tin)(dựa trên Đơn vị hành chính mới theo quy định)</label>
        <input asp-for="UngVien.DiaChiCuTru" class="form-control" placeholder="Ví dụ: 59 Nguyễn Thị Minh Khai, phường Bến Thành, Thành phố Hồ Chí Minh" />
        <span asp-validation-for="UngVien.DiaChiCuTru" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.MaSoThue" class="form-label">Mã số thuế</label>
        <input asp-for="UngVien.MaSoThue" class="form-control" maxlength="13" />
        <span asp-validation-for="UngVien.MaSoThue" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.SoTaiKhoan" class="form-label">Số tài khoản ngân hàng Vietinbank chi nhánh 7</label>
        <input asp-for="UngVien.SoTaiKhoan" class="form-control" maxlength="12" />
        <span asp-validation-for="UngVien.SoTaiKhoan" class="text-danger"></span>
    </div>

    <!-- Tình trạng sức khỏe -->
    <div class="form-group">
        <label class="form-label fw-bold">Tình trạng sức khỏe</label>
        <input type="hidden" asp-for="UngVien.TinhTrangSucKhoe" id="hidSK" />
        <div class="choice-vertical">
            <label class="choice-item"><input class="radio-solid js-sk" type="radio" name="skUI" value="Loại I"> Loại I</label>
            <label class="choice-item"><input class="radio-solid js-sk" type="radio" name="skUI" value="Loại II"> Loại II</label>
            <label class="choice-item"><input class="radio-solid js-sk" type="radio" name="skUI" value="Loại III"> Loại III</label>
            <label class="choice-item"><input class="radio-solid js-sk" type="radio" name="skUI" value="__OTHER__" id="skKhac"> Khác:</label>
        </div>
        <input id="txtSkKhac" name="TinhTrangSucKhoeKhac" class="form-control mt-2" placeholder="Nhập tình trạng khác" style="display:none;" />
        <span asp-validation-for="UngVien.TinhTrangSucKhoe" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.TrinhDoChuyenMon" class="form-label">Trình độ chuyên môn/Trình độ đào tạo</label>
        <input asp-for="UngVien.TrinhDoChuyenMon" class="form-control" placeholder="Ví dụ: Cử nhân Quản lý nhà nước/ Bác sĩ Chuyên khoa cấp II..." />
        <span asp-validation-for="UngVien.TrinhDoChuyenMon" class="text-danger"></span>
    </div>

    <hr class="hr-soft" />
    <h4 class="section-title">Thông tin hợp đồng người lao động</h4>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.KhoaPhongCongTacId" class="form-label">Khoa/phòng hiện đang công tác</label>
        <select asp-for="HopDongNguoiLaoDong.KhoaPhongCongTacId" class="form-control" asp-items="ViewBag.KhoaPhongList">
            <option value="">-- Chọn khoa/phòng --</option>
        </select>
        <span asp-validation-for="HopDongNguoiLaoDong.KhoaPhongCongTacId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.NoiSinh" class="form-label">Nơi sinh (Ghi theo đơn vị hành chính cấp tỉnh)</label>
        <input asp-for="HopDongNguoiLaoDong.NoiSinh" class="form-control" placeholder="Ví dụ: Thành phố Hồ Chí Minh, tỉnh Lâm Đồng" />
        <span asp-validation-for="HopDongNguoiLaoDong.NoiSinh" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.ChuyenNganhDaoTao" class="form-label">Chuyên ngành đào tạo</label>
        <input asp-for="HopDongNguoiLaoDong.ChuyenNganhDaoTao" class="form-control" placeholder="Ví dụ: Quản lý nhà nước/ Tổ chức quản lý y tế/ Bác sĩ y khoa,..."/>
        <span asp-validation-for="HopDongNguoiLaoDong.ChuyenNganhDaoTao" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.NamTotNghiep" class="form-label">Năm tốt nghiệp</label>
        <input asp-for="HopDongNguoiLaoDong.NamTotNghiep" class="form-control" placeholder="Ví dụ: Cử nhân Quản lý bệnh viện: năm 2020"/>
        <span asp-validation-for="HopDongNguoiLaoDong.NamTotNghiep" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.TrinhDoTinHoc" class="form-label">Trình độ tin học (nếu có điền đầy đủ tên)</label>
        <input asp-for="HopDongNguoiLaoDong.TrinhDoTinHoc" class="form-control" placeholder="Ví dụ: Ứng dụng công nghệ thông tin cơ bản hoặc điền 'Không có'"/>
        <span asp-validation-for="HopDongNguoiLaoDong.TrinhDoTinHoc" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.TrinhDoNgoaiNgu" class="form-label">Trình độ ngoại ngữ (nếu có điền đầy đủ tên)</label>
        <input asp-for="HopDongNguoiLaoDong.TrinhDoNgoaiNgu" class="form-control" placeholder="Ví dụ: Tiếng anh trình độ B1/ IELTS 9.0/ TOEIC 990 hoặc điền 'Không có'"/>
        <span asp-validation-for="HopDongNguoiLaoDong.TrinhDoNgoaiNgu" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.ChungChiHanhNghe" class="form-label">Chứng chỉ hành nghề (nếu có điền đầy đủ số hiệu)</label>
        <input asp-for="HopDongNguoiLaoDong.ChungChiHanhNghe" class="form-control" placeholder="Ví dụ: 01234/HCM-CCHN hoặc điền 'Không có'"/>
        <span asp-validation-for="HopDongNguoiLaoDong.ChungChiHanhNghe" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.NgheNghiepTruocTuyenDung" class="form-label">Nghề nghiệp trước tuyển dụng (nếu có)</label>
        <input asp-for="HopDongNguoiLaoDong.NgheNghiepTruocTuyenDung" class="form-control" placeholder="Nếu không điền 'Không có'" />
        <span asp-validation-for="HopDongNguoiLaoDong.NgheNghiepTruocTuyenDung" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Nộp đơn</button>
</form>

@section Styles {
    <link rel="stylesheet" href="~/css/apply-forms.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/apply-date.js" asp-append-version="true"></script>
    <script src="~/js/apply-email.js" asp-append-version="true"></script>
    <script src="~/js/apply-macdinh.js" asp-append-version="true"></script>
    <script src="~/js/apply-init.js" asp-append-version="true"></script>
    <script src="~/js/apply-suckhoe.js" asp-append-version="true"></script>
}

