@model BVUB_WebTuyenDung.Models.UngTuyenNguoiLaoDongViewModel
@{
    ViewData["Title"] = "Ứng tuyển người lao động";
}
<h2>@ViewData["Title"]</h2>

<form asp-action="UngTuyenNguoiLaoDong" method="post" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <h4>Thông tin ứng viên</h4>

    <!-- Email + Kiểm tra -->
    <div class="form-group">
        <label asp-for="UngVien.Email">Email</label>
        <div style="display:flex; gap:8px;">
            <input asp-for="UngVien.Email" class="form-control" id="txtEmail" />
            <button type="button" id="btnCheckEmail" class="btn btn-secondary">Kiểm tra</button>
        </div>
        <small id="emailHint" class="text-muted"></small>
        <span asp-validation-for="UngVien.Email" class="text-danger"></span>
    </div>

    <!-- Loại hồ sơ -->
    <div class="form-group" style="max-width:320px;">
        <label>Loại hồ sơ</label>
        <select id="loaiHoSo" class="form-control">
            <option value="NguoiLaoDong" selected>Người lao động</option>
            <option value="VienChuc">Viên chức</option>
        </select>
    </div>

    <!-- Các trường Ứng viên -->
    <div class="form-group">
        <label asp-for="UngVien.HoTen">Họ và tên</label>
        <input asp-for="UngVien.HoTen" class="form-control" />
        <span asp-validation-for="UngVien.HoTen" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.GioiTinh">Giới tính</label>
        <select asp-for="UngVien.GioiTinh" class="form-control">
            <option value="0">Nam</option>
            <option value="1">Nữ</option>
            <option value="2">Khác</option>
        </select>
        <span asp-validation-for="UngVien.GioiTinh" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NgaySinh">Ngày tháng năm sinh</label>
        <input asp-for="UngVien.NgaySinh" type="date" class="form-control" />
        <span asp-validation-for="UngVien.NgaySinh" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.SoDienThoai">Số điện thoại</label>
        <input asp-for="UngVien.SoDienThoai" class="form-control" />
        <span asp-validation-for="UngVien.SoDienThoai" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.CCCD">Số căn cước công dân hoặc căn cước</label>
        <input asp-for="UngVien.CCCD" class="form-control" maxlength="12" />
        <span asp-validation-for="UngVien.CCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NgayCapCCCD">Ngày cấp</label>
        <input asp-for="UngVien.NgayCapCCCD" type="date" class="form-control" />
        <span asp-validation-for="UngVien.NgayCapCCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.NoiCapCCCD">Nơi cấp Thẻ căn cước công dân hoặc thẻ căn cước</label>
        <select asp-for="UngVien.NoiCapCCCD" class="form-control">
            <option value="">-- Chọn nơi cấp --</option>
            <option value="Bộ Công an">Bộ Công an</option>
            <option value="Cục Cảnh sát quản lý hành chính về trật tự xã hội">
                Cục Cảnh sát quản lý hành chính về trật tự xã hội
            </option>
            <option value="Cục Cảnh sát đăng ký quản lý cư trú và dữ liệu Quốc gia về dân cư">
                Cục Cảnh sát đăng ký quản lý cư trú và dữ liệu Quốc gia về dân cư
            </option>
        </select>
        <span asp-validation-for="UngVien.NoiCapCCCD" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.DiaChiThuongTru">Địa chỉ thường trú</label>
        <input asp-for="UngVien.DiaChiThuongTru" class="form-control" />
        <span asp-validation-for="UngVien.DiaChiThuongTru" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.DiaChiCuTru">Địa chỉ cư trú</label>
        <input asp-for="UngVien.DiaChiCuTru" class="form-control" />
        <span asp-validation-for="UngVien.DiaChiCuTru" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.MaSoThue">Mã số thuế</label>
        <input asp-for="UngVien.MaSoThue" class="form-control" maxlength="13" />
        <span asp-validation-for="UngVien.MaSoThue" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.SoTaiKhoan">Số tài khoản ngân hàng Vietinbank chi nhánh 7</label>
        <input asp-for="UngVien.SoTaiKhoan" class="form-control" maxlength="12" />
        <span asp-validation-for="UngVien.SoTaiKhoan" class="text-danger"></span>
    </div>

    <!-- Tình trạng sức khỏe -->
    <div class="form-group">
        <label class="form-label fw-bold">Tình trạng sức khỏe</label>

        <!-- field thật gửi về server -->
        <input type="hidden" asp-for="UngVien.TinhTrangSucKhoe" id="hidSK" />

        <div class="choice-group">
            <label class="choice-item">
                <input class="radio-solid js-sk" type="radio" name="skUI" value="Loại I"> Loại I
            </label>
            <label class="choice-item">
                <input class="radio-solid js-sk" type="radio" name="skUI" value="Loại II"> Loại II
            </label>
            <label class="choice-item">
                <input class="radio-solid js-sk" type="radio" name="skUI" value="Loại III"> Loại III
            </label>
            <label class="choice-item">
                <input class="radio-solid js-sk" type="radio" name="skUI" value="__OTHER__" id="skKhac"> Khác:
            </label>
        </div>

        <input id="txtSkKhac" class="form-control mt-2" type="text"
               placeholder="Nhập tình trạng khác" style="display:none;" />

        <span asp-validation-for="UngVien.TinhTrangSucKhoe" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="UngVien.TrinhDoChuyenMon">Trình độ chuyên môn</label>
        <input asp-for="UngVien.TrinhDoChuyenMon" class="form-control" />
        <span asp-validation-for="UngVien.TrinhDoChuyenMon" class="text-danger"></span>
    </div>

    <hr />
    <h4>Thông tin hợp đồng người lao động</h4>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.KhoaPhongCongTacId">Khoa/phòng hiện đang công tác</label>
        <select asp-for="HopDongNguoiLaoDong.KhoaPhongCongTacId" class="form-control" asp-items="ViewBag.KhoaPhongList">
            <option value="">-- Chọn khoa/phòng --</option>
        </select>
        <span asp-validation-for="HopDongNguoiLaoDong.KhoaPhongCongTacId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.NoiSinh">Nơi sinh</label>
        <input asp-for="HopDongNguoiLaoDong.NoiSinh" class="form-control" />
        <span asp-validation-for="HopDongNguoiLaoDong.NoiSinh" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.ChuyenNganhDaoTao">Chuyên ngành đào tạo</label>
        <input asp-for="HopDongNguoiLaoDong.ChuyenNganhDaoTao" class="form-control" />
        <span asp-validation-for="HopDongNguoiLaoDong.ChuyenNganhDaoTao" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.NamTotNghiep">Năm tốt nghiệp</label>
        <input asp-for="HopDongNguoiLaoDong.NamTotNghiep" class="form-control" />
        <span asp-validation-for="HopDongNguoiLaoDong.NamTotNghiep" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.TrinhDoTinHoc">Trình độ tin học</label>
        <input asp-for="HopDongNguoiLaoDong.TrinhDoTinHoc" class="form-control" />
        <span asp-validation-for="HopDongNguoiLaoDong.TrinhDoTinHoc" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.TrinhDoNgoaiNgu">Trình độ ngoại ngữ</label>
        <input asp-for="HopDongNguoiLaoDong.TrinhDoNgoaiNgu" class="form-control" />
        <span asp-validation-for="HopDongNguoiLaoDong.TrinhDoNgoaiNgu" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.ChungChiHanhNghe">Chứng chỉ hành nghề (nếu có)</label>
        <input asp-for="HopDongNguoiLaoDong.ChungChiHanhNghe" class="form-control" />
        <span asp-validation-for="HopDongNguoiLaoDong.ChungChiHanhNghe" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="HopDongNguoiLaoDong.NgheNghiepTruocTuyenDung">Nghề nghiệp trước tuyển dụng</label>
        <input asp-for="HopDongNguoiLaoDong.NgheNghiepTruocTuyenDung" class="form-control" />
        <span asp-validation-for="HopDongNguoiLaoDong.NgheNghiepTruocTuyenDung" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Nộp đơn</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
  (function () {
    const $email = $('#txtEmail');
    const $hint  = $('#emailHint');
    const emailRegex = /^[^@@\s]+@@gmail\.com$/i;

    let lastCheckedEmail = null;
    let canSubmit = false;

    function setHint(msg, isErr){
      $hint.text(msg || '')
           .toggleClass('text-danger', !!isErr)
           .toggleClass('text-muted', !isErr);
    }

            function formatDate(iso) {
            return iso ? iso.split('T')[0] : '';
        }

    // CHỈ FILL các field UngVien.*
    function fillUngVien(u){
      if (!u) return;
      $('[name="UngVien.HoTen"]').val(u.HoTen ?? u.hoTen ?? '');
      $('[name="UngVien.GioiTinh"]').val(u.GioiTinh ?? u.gioiTinh ?? 0);
            $('[name="UngVien.NgaySinh"]').val(formatDate(u.NgaySinh ?? u.ngaySinh));
      $('[name="UngVien.SoDienThoai"]').val(u.SoDienThoai ?? u.soDienThoai ?? '');
      $('[name="UngVien.Email"]').val(u.Email ?? u.email ?? '');
      $('[name="UngVien.CCCD"]').val(u.CCCD ?? u.cccd ?? '');
            $('[name="UngVien.NgayCapCCCD"]').val(formatDate(u.NgayCapCCCD ?? u.ngayCapCCCD));
      $('[name="UngVien.NoiCapCCCD"]').val(u.NoiCapCCCD ?? u.noiCapCCCD ?? '');
      $('[name="UngVien.DiaChiThuongTru"]').val(u.DiaChiThuongTru ?? u.diaChiThuongTru ?? '');
      $('[name="UngVien.DiaChiCuTru"]').val(u.DiaChiCuTru ?? u.diaChiCuTru ?? '');
      $('[name="UngVien.MaSoThue"]').val(u.MaSoThue ?? u.maSoThue ?? '');
      $('[name="UngVien.SoTaiKhoan"]').val(u.SoTaiKhoan ?? u.soTaiKhoan ?? '');

      // Tình trạng sức khỏe
              const sk = (u.TinhTrangSucKhoe ?? u.tinhTrangSucKhoe ?? '').trim();
        if (sk) {
          if (window.setTinhTrangSucKhoe) window.setTinhTrangSucKhoe(sk);
        }

      $('[name="UngVien.TrinhDoChuyenMon"]').val(u.TrinhDoChuyenMon ?? u.trinhDoChuyenMon ?? '');
    }

    $email.on('input', function(){
      lastCheckedEmail = null;
      canSubmit = false;
      setHint('');
    });

            $('#btnCheckEmail').on('click', function(){
            const email = ($email.val() || '').trim();
            if (!email) { setHint('Vui lòng nhập Email trước.', true); return; }
            if (!emailRegex.test(email)) { setHint('Sai định dạng (chỉ chấp nhận @@gmail.com).', true); return; }

            setHint('Đang kiểm tra...');
            $.getJSON('@Url.Action("CheckEmail", "UngTuyen")', { email })
             .done(function(res){
                lastCheckedEmail = email;
                if (!res || !res.ok) {
                    setHint(res?.message || 'Không kiểm tra được Email.', true);
                    canSubmit=false;
                    return;
                }

                if (!res.exists) {
                    setHint('Email hợp lệ và chưa tồn tại. Bạn có thể nộp đơn.', false);
                    canSubmit = true;
                    return;
                }

                // ✅ Nếu tồn tại ứng viên → fill dữ liệu
                if (res.ungVien) {
                    fillUngVien(res.ungVien);
                }

                if (res.hasHopDong) {
                    setHint('Email này đã có hồ sơ NGƯỜI LAO ĐỘNG. Không thể nộp thêm.', true);
                    canSubmit = false;
                } else {
                    setHint('Đã tìm thấy hồ sơ. Thông tin Ứng viên đã được điền sẵn, bạn có thể nộp đơn.', false);
                    canSubmit = true;
                }
             })
             .fail(function(){
                 setHint('Lỗi kết nối. Vui lòng thử lại.', true);
                 canSubmit = false;
             });
        });


    // Chặn submit nếu chưa bấm "Kiểm tra"
    $('form').on('submit', function(e){
      const email = ($email.val() || '').trim();
      if (!lastCheckedEmail || email !== lastCheckedEmail) {
        e.preventDefault();
        setHint('Vui lòng nhập Email và bấm "Kiểm tra" trước khi nộp.', true);
        alert('Vui lòng kiểm tra Email trước khi nộp đơn.');
        return;
      }
      if (!canSubmit) {
        e.preventDefault();
        setHint('Bạn không đủ điều kiện nộp đơn với Email này.', true);
        alert('Bạn không đủ điều kiện nộp đơn với Email này.');
      }
    });
  })();
</script>

    <script>
        (function () {
          const radios = document.querySelectorAll('.js-sk');
          const hid    = document.getElementById('hidSK');
          const txt    = document.getElementById('txtSkKhac');
          const rOther = document.getElementById('skKhac');
          const KNOWN  = ['Loại I','Loại II','Loại III'];

          function reflectHiddenToUI() {
            const val = (hid.value || '').trim();
            if (!val) {
              txt.style.display = 'none'; txt.value = '';
              radios.forEach(r => r.checked = false);
              return;
            }
            if (KNOWN.includes(val)) {
              txt.style.display = 'none'; txt.value = '';
              radios.forEach(r => r.checked = (r.value === val));
            } else {
              rOther.checked = true;
              txt.style.display = 'block';
              txt.value = val;
            }
          }

          // Khi chọn radio
          radios.forEach(r => r.addEventListener('change', function () {
            if (this.value === '__OTHER__') {
              txt.style.display = 'block';
              hid.value = txt.value.trim();   // ngay lúc bật “Khác”
            } else {
              txt.style.display = 'none';
              txt.value = '';
              hid.value = this.value;         // Loại I/II/III
            }
          }));

          // Khi gõ ô “Khác”
          txt.addEventListener('input', function () {
            if (rOther.checked) hid.value = this.value.trim();
          });

          // chạy lúc load (nếu server đã bind hidden)
          reflectHiddenToUI();

          // Hàm public để fill từ Ajax
          window.setTinhTrangSucKhoe = function (sk) {
            hid.value = (sk || '').trim();
            reflectHiddenToUI();
          };
        })();
    </script>
}
