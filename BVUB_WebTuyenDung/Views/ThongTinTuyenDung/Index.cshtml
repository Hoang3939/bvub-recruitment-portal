model IEnumerable<BVUB_WebTuyenDung.Models.ThongTinTuyenDung>

@{
    ViewData["Title"] = "Danh sách Thông Tin Tuyển Dụng";
}

    <h2>@ViewData["Title"]</h2>

    <p>
        <a asp-action="Create" class="btn btn-primary">Tạo mới</a>
    </p>

    <table class="table table-bordered">
        <thead class="thead-light">
            <tr>
                <th>Tiêu đề</th>
                <th>Ngày đăng</th>
                <th>Hạn nộp</th>
                <th>Loại</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TieuDe</td>
                    <td>@item.NgayDang.ToString("dd/MM/yyyy")</td>
                    <td>@item.HanNopHoSo.ToString("dd/MM/yyyy")</td>
                    <td>@item.LoaiTuyenDung</td>
                    <td>@item.TrangThai</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.TuyenDungId" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Details" asp-route-id="@item.TuyenDungId" class="btn btn-sm btn-info">Chi tiết</a>
                        <a asp-action="Delete" asp-route-id="@item.TuyenDungId" class="btn btn-sm btn-danger">Xoá</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
