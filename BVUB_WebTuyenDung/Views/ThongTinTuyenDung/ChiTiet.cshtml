@model BVUB_WebTuyenDung.Models.ThongTinTuyenDung
@using System

@{
    ViewData["Title"] = "Chi tiết tuyển dụng";

    string LabelLoai(string? loai) => (loai ?? "").ToUpperInvariant() switch
    {
        "VC" => "Viên chức",
        "NLD" => "Người lao động",
        _ => "Khác"
    };

    // Chuẩn hóa URL tệp/ảnh
    string? fileUrl = null;
    if (!string.IsNullOrWhiteSpace(Model.FileDinhKem))
    {
        var raw = Model.FileDinhKem.Trim();
        fileUrl = raw.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? raw
            : Url.Content(raw.StartsWith("/") ? raw : "~/uploads/" + raw);
    }

    bool isImage = fileUrl != null && (
        fileUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
        fileUrl.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
        fileUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
        fileUrl.EndsWith(".webp", StringComparison.OrdinalIgnoreCase) ||
        fileUrl.EndsWith(".gif", StringComparison.OrdinalIgnoreCase)
    );

    var days = (Model.HanNopHoSo.Date - DateTime.Today).TotalDays;
    var daysText = days < 0 ? "Đã hết hạn"
                  : days == 0 ? "Hạn nộp hôm nay"
                  : $"Còn {Math.Ceiling(days)} ngày";
}

@section Styles {
    <link rel="stylesheet" href="~/css/tuyendung.css" asp-append-version="true" />
    <style>
        /* cover image cho chi tiết */
        
    </style>
}

<div class="td-detail">
    <h1 class="td-detail__title">@Model.TieuDe</h1>

    <div class="td-detail__meta">
        <span class="td-badge">@LabelLoai(Model.LoaiTuyenDung)</span>
        <span>Ngày đăng: @Model.NgayDang.ToString("dd/MM/yyyy")</span>
        <span>Hạn nộp: @Model.HanNopHoSo.ToString("dd/MM/yyyy")</span>
        <span class="td-remain @(days <= 3 && days >= 0 ? "is-hot" : "")">@daysText</span>
    </div>

    @* Hiển thị ảnh cover nếu FileDinhKem là ảnh *@
    @if (isImage)
    {
        <div class="td-detail__cover">
            <img src="@fileUrl" alt="Hình tuyển dụng" />
        </div>
    }

    <div class="td-detail__content">
        @Html.Raw(Model.NoiDung)  @* Nội dung từ admin *@
    </div>

    @* Link tải tệp đính kèm nếu không phải ảnh (hoặc bạn vẫn muốn cho tải ảnh) *@
    @if (!string.IsNullOrWhiteSpace(fileUrl))
    {
        <div class="td-detail__files">
            <a href="@fileUrl" class="td-btn td-btn--primary" target="_blank" rel="noopener">
                Tải tệp đính kèm
            </a>
        </div>
    }

    <div style="margin-top:16px;">
        <a asp-action="Index" class="td-btn">← Quay lại danh sách</a>
    </div>
</div>