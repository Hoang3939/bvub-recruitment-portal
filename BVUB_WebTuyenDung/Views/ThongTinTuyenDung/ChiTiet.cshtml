@model BVUB_WebTuyenDung.Models.ThongTinTuyenDung
@using System
@using System.IO
@{
    ViewData["Title"] = "Chi tiết tuyển dụng";

    string LabelLoai(string? loai) => (loai ?? "").ToUpperInvariant() switch
    {
        "VC" => "Viên chức",
        "NLD" => "Người lao động",
        _ => "Khác"
    };

    // Chuẩn hoá URL đính kèm (giữ nguyên nếu là http/https)
    string? attachUrl = null;
    if (!string.IsNullOrWhiteSpace(Model.FileDinhKem))
    {
        var raw = Model.FileDinhKem.Trim();
        attachUrl = raw.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? raw
            : Url.Content(raw.StartsWith("/") ? raw : "~/uploads/" + raw);
    }

    // Xác định có phải ảnh không (KHÔNG dùng pattern "or", dùng so sánh chuỗi thường)
    var ext = string.IsNullOrWhiteSpace(attachUrl)
        ? ""
        : System.IO.Path.GetExtension(attachUrl!).ToLowerInvariant();

    var isImage = ext == ".png" || ext == ".jpg" || ext == ".jpeg" || ext == ".webp" || ext == ".gif";

    var days = (Model.HanNopHoSo.Date - DateTime.Today).TotalDays;
    var daysText = days < 0 ? "Đã hết hạn"
                : days == 0 ? "Hạn nộp hôm nay"
                : $"Còn {Math.Ceiling(days)} ngày";
}

@section Styles {
    <link rel="stylesheet" href="~/css/tuyendung.css" asp-append-version="true" />
}

<div class="td-detail">
    <h1 class="td-detail__title">@Model.TieuDe</h1>

    <div class="td-detail__meta">
        <span class="td-badge">@LabelLoai(Model.LoaiTuyenDung)</span>
        <span>Ngày đăng: @Model.NgayDang.ToString("dd/MM/yyyy")</span>
        <span>Hạn nộp: @Model.HanNopHoSo.ToString("dd/MM/yyyy")</span>
        <span class="td-remain @(days <= 3 && days >= 0 ? "is-hot" : "")">@daysText</span>
    </div>

    @if (isImage)
    {
        <div class="td-detail__cover">
            <img src="@attachUrl" alt="Hình tuyển dụng" />
        </div>
    }

    <div class="td-detail__content">
        @Html.Raw(Model.NoiDung)
    </div>

    @if (!string.IsNullOrWhiteSpace(attachUrl))
    {
        var downloadLabel = ext == ".pdf" ? "Tải PDF"
        : (ext == ".doc" || ext == ".docx") ? "Tải Word"
        : "Tải tệp đính kèm";
        <div class="td-detail__files" style="margin-top:12px;">
            <a href="@attachUrl" class="td-btn td-btn--primary" target="_blank" rel="noopener">
                @downloadLabel
            </a>
        </div>
    }

    <div style="margin-top:16px;">
        <a asp-action="Index" class="td-btn">← Quay lại danh sách</a>
    </div>
</div>