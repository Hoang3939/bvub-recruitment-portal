@model BVUB_WebTuyenDung.Models.ThongTinTuyenDung

@{
    ViewData["Title"] = "Chỉnh sửa Thông Tin Tuyển Dụng";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="TuyenDungId" />
    <div class="form-group">
        <label asp-for="TieuDe"></label>
        <input asp-for="TieuDe" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="NoiDung"></label>
        <textarea asp-for="NoiDung" class="form-control"></textarea>
    </div>
    <div class="form-group">
        <label asp-for="NgayDang"></label>
        <input asp-for="NgayDang" type="date" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="HanNopHoSo"></label>
        <input asp-for="HanNopHoSo" type="date" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="LoaiTuyenDung"></label>
        <input asp-for="LoaiTuyenDung" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="FileDinhKem"></label>
        <input asp-for="FileDinhKem" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="TrangThai"></label>
        <input asp-for="TrangThai" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary">Huỷ</a>
</form>